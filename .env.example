# Copy to .env.local for local dev. Never commit .env.local.
# All of these must be set as Netlify environment secrets before deploying.

# ─── Anthropic (required for all agents) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Neon Postgres (required for Phase 2+) ──────────────────────────────────
# Get from Neon console → Dashboard → Connection string
# Or auto-provisioned via Netlify DB (Site Config → Databases)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# ─── Admin dashboard ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=...

# ─── Phase 3 (add when building Concierge email + Slack) ────────────────────
RESEND_API_KEY=re_...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Cal.com webhook (discovery call bookings) ──────────────────────────────
# Cal.com → Settings → Webhooks → copy the signing secret for
# https://thelivingcraft.ai/.netlify/functions/cal-webhook
CAL_WEBHOOK_SECRET=...

# ─── Orchestrator / budget ──────────────────────────────────────────────────
# Monthly Anthropic spend ceiling in USD — agents pause when hit.
ANTHROPIC_MONTHLY_BUDGET_USD=20
# Where the daily brief email lands
OWNER_EMAIL=the-founder@thelivingcraft.ai

# ─── Admin HTTP Basic Auth (gates /admin/* and /api/admin/*) ────────────────
# Leave both unset to disable the gate (dev only). In prod, set both.
ADMIN_USERNAME=sunil
ADMIN_PASSWORD=...

# ─── Phase 4 (add when building Scribe) ─────────────────────────────────────
BRAVE_SEARCH_API_KEY=...
