---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
}

const {
  title,
  description = 'Practitioner-grade Agentic AI training, mentoring, and consulting for senior technical leaders.',
  ogTitle,
  ogDescription,
  ogImage,
  ogType,
  canonical,
  noindex,
  schema,
} = Astro.props;

const fullTitle = title === 'The Living Craft' ? title : `${title} | The Living Craft`;
---

<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <SEO
      title={fullTitle}
      description={description}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
      schema={schema}
    />
  </head>
  <body class="bg-dark-primary text-white font-sans min-h-screen antialiased">

    <!-- ─── NAVBAR ──────────────────────────────────────────── -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-800/60"
            style="background: rgba(10,10,15,0.90); backdrop-filter: blur(14px);">
      <nav class="container mx-auto px-6 h-16 flex items-center justify-between gap-8">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 flex-shrink-0 group">
          <div class="h-11 w-auto rounded-lg overflow-hidden border border-gray-700/50 group-hover:border-accent/40 transition-colors duration-200 shadow-md"
               style="background: #f0ebe0; aspect-ratio: 300/420;">
            <img
              src="/TheLivingCraftlogo.png"
              alt="The Living Craft"
              class="h-full w-auto object-contain"
            />
          </div>
          <span class="text-lg font-bold tracking-tight leading-none hidden sm:block">
            The Living <span class="text-accent">Craft</span>
          </span>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-7 text-sm text-gray-400">
          <a href="/training/"   class="hover:text-white transition-colors duration-150">Training</a>
          <a href="/mentoring/"  class="hover:text-white transition-colors duration-150">Mentoring</a>
          <a href="/consulting/" class="hover:text-white transition-colors duration-150">Consulting</a>
          <a href="/blog/"       class="hover:text-white transition-colors duration-150">Blog</a>
          <a href="/projects/"   class="hover:text-white transition-colors duration-150">Projects</a>
          <a href="/about/"      class="hover:text-white transition-colors duration-150">About</a>
        </div>

        <!-- CTA + hamburger -->
        <div class="flex items-center gap-4">
          <a href="/contact/" class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 bg-accent hover:bg-accent-light text-white text-sm font-semibold rounded-lg transition-colors duration-150 shadow-md shadow-accent/20">
            Book a Call
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <button id="menu-toggle" class="md:hidden p-2 text-gray-400 hover:text-white transition-colors" aria-label="Toggle menu">
            <svg id="icon-open"  class="w-5 h-5"        fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-800 bg-dark-primary/95">
        <div class="container mx-auto px-6 py-6 flex flex-col gap-1">
          <a href="/training/"   class="py-3 text-gray-300 hover:text-white transition-colors border-b border-gray-800/50 text-sm">Training</a>
          <a href="/mentoring/"  class="py-3 text-gray-300 hover:text-white transition-colors border-b border-gray-800/50 text-sm">Mentoring</a>
          <a href="/consulting/" class="py-3 text-gray-300 hover:text-white transition-colors border-b border-gray-800/50 text-sm">Consulting</a>
          <a href="/blog/"       class="py-3 text-gray-300 hover:text-white transition-colors border-b border-gray-800/50 text-sm">Blog</a>
          <a href="/projects/"   class="py-3 text-gray-300 hover:text-white transition-colors border-b border-gray-800/50 text-sm">Projects</a>
          <a href="/about/"      class="py-3 text-gray-300 hover:text-white transition-colors text-sm">About</a>
          <a href="/contact/" class="mt-4 px-4 py-3 bg-accent hover:bg-accent-light text-white font-semibold rounded-lg text-center text-sm transition-colors">
            Book a Call →
          </a>
        </div>
      </div>
    </header>

    <!-- Nav spacer -->
    <div class="h-16"></div>

    <!-- ─── PAGE CONTENT ────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ─── FOOTER ──────────────────────────────────────────── -->
    <footer class="border-t border-gray-800 pt-16 pb-10">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-14">

          <!-- Brand col -->
          <div>
            <!-- Logo card — larger in footer -->
            <a href="/" class="block w-32 mb-5 rounded-xl overflow-hidden border border-gray-700/50 hover:border-accent/30 transition-colors duration-200 shadow-xl"
               style="background: #f0ebe0;">
              <img
                src="/TheLivingCraftlogo.png"
                alt="The Living Craft"
                class="w-full h-auto object-contain"
              />
            </a>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">
              Practitioner-grade Agentic AI training, mentoring, and consulting for senior technical leaders.
            </p>
            <div class="flex flex-col gap-1">
              <p class="text-xs font-mono text-gray-600 uppercase tracking-widest">
                AI · Training · Consulting · Projects
              </p>
              <p class="text-xs font-mono text-accent/60 uppercase tracking-widest">
                Ultra Fast Learning
              </p>
            </div>
            <a href="https://linkedin.com" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-gray-400 hover:text-white text-xs font-mono transition-colors mt-5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>

          <!-- Services -->
          <div>
            <h4 class="text-xs font-semibold text-white mb-5 uppercase tracking-widest">Services</h4>
            <ul class="space-y-3 text-sm text-gray-400">
              <li><a href="/training/"   class="hover:text-white transition-colors">Training</a></li>
              <li><a href="/mentoring/"  class="hover:text-white transition-colors">Mentoring</a></li>
              <li><a href="/consulting/" class="hover:text-white transition-colors">Consulting</a></li>
              <li><a href="/blog/"       class="hover:text-white transition-colors">Blog & Projects</a></li>
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h4 class="text-xs font-semibold text-white mb-5 uppercase tracking-widest">Company</h4>
            <ul class="space-y-3 text-sm text-gray-400">
              <li><a href="/about/"    class="hover:text-white transition-colors">About</a></li>
              <li><a href="/contact/"  class="hover:text-white transition-colors">Contact</a></li>
              <li><a href="/blog/"     class="hover:text-white transition-colors">Blog</a></li>
              <li><a href="/projects/" class="hover:text-white transition-colors">Projects</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="text-xs font-semibold text-white mb-5 uppercase tracking-widest">Legal</h4>
            <ul class="space-y-3 text-sm text-gray-400">
              <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms/"   class="hover:text-white transition-colors">Terms of Service</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
          <p class="text-gray-500 text-sm">© 2026 The Living Craft. All rights reserved.</p>
          <p class="text-gray-600 text-xs font-mono">Practitioner-grade AI leadership.</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle    = document.getElementById('menu-toggle');
      const menu      = document.getElementById('mobile-menu');
      const iconOpen  = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        iconOpen?.classList.toggle('hidden');
        iconClose?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
