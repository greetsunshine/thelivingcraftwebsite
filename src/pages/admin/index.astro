---
export const prerender = false;

import { queryPipelineSummary, queryRecentRuns } from '../../lib/db';

let summary = { total: 0, byStage: {} as Record<string, number>, byIntent: {} as Record<string, number>, highUrgency: 0 };
let recentRuns: Awaited<ReturnType<typeof queryRecentRuns>> = [];
let dbError = '';

try {
  [summary, recentRuns] = await Promise.all([queryPipelineSummary(), queryRecentRuns(10)]);
} catch (err) {
  dbError = err instanceof Error ? err.message : String(err);
}

function formatDuration(ms?: number): string {
  if (!ms) return '—';
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleString('en-US', {
    month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',
  });
}

const stageOrder = ['new_lead', 'contacted', 'qualified', 'proposal_sent', 'closed_won', 'closed_lost'];
const intentOrder = ['training', 'mentoring', 'consulting', 'other'];
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard — The Living Craft</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: #0a0a0f; color: #e2e8f0; min-height: 100vh; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    header { border-bottom: 1px solid #1e293b; padding: 16px 0; }
    header .inner { display: flex; align-items: center; justify-content: space-between; }
    header h1 { font-size: 14px; font-weight: 600; color: #fff; margin: 0; }
    header nav { display: flex; gap: 24px; }
    header nav a { font-size: 13px; color: #94a3b8; text-decoration: none; }
    header nav a:hover, header nav a.active { color: #fff; }
    .page-title { margin: 32px 0 8px; font-size: 24px; font-weight: 700; color: #fff; }
    .page-subtitle { font-size: 13px; color: #64748b; margin: 0 0 32px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: #16213e; border: 1px solid #1e293b; border-radius: 10px; padding: 20px; }
    .stat-card .label { font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
    .stat-card .value { font-size: 32px; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; }
    .stat-card .sub { font-size: 12px; color: #475569; margin-top: 4px; }
    .section-title { font-size: 14px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 16px; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .panel { background: #16213e; border: 1px solid #1e293b; border-radius: 10px; padding: 24px; }
    .bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .bar-label { font-size: 12px; color: #94a3b8; min-width: 120px; font-family: 'JetBrains Mono', monospace; }
    .bar-track { flex: 1; background: #1e293b; border-radius: 4px; height: 6px; }
    .bar-fill { height: 6px; border-radius: 4px; background: #4f46e5; }
    .bar-count { font-size: 12px; color: #64748b; font-family: 'JetBrains Mono', monospace; min-width: 24px; text-align: right; }
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #475569; padding: 0 12px 10px; text-align: left; }
    td { font-size: 13px; color: #94a3b8; padding: 10px 12px; border-top: 1px solid #1e293b; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-family: 'JetBrains Mono', monospace; font-weight: 500; }
    .badge-success { background: #052e16; color: #4ade80; border: 1px solid #166534; }
    .badge-failed { background: #2d0a0a; color: #f87171; border: 1px solid #7f1d1d; }
    .badge-running { background: #1c1535; color: #a78bfa; border: 1px solid #4c1d95; }
    .error-banner { background: #2d0a0a; border: 1px solid #7f1d1d; border-radius: 8px; padding: 16px; color: #f87171; font-size: 13px; margin-bottom: 24px; font-family: 'JetBrains Mono', monospace; }
    @media (max-width: 768px) { .grid-4 { grid-template-columns: 1fr 1fr; } .two-col { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <header>
    <div class="container inner">
      <h1>The Living Craft <span class="mono" style="color:#4f46e5">/admin</span></h1>
      <nav>
        <a href="/admin/" class="active">Overview</a>
        <a href="/admin/leads/">Leads</a>
        <a href="/">← Site</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <h2 class="page-title">Pipeline Overview</h2>
    <p class="page-subtitle mono">Agent-managed CRM · {new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })}</p>

    {dbError && (
      <div class="error-banner">DB error: {dbError}</div>
    )}

    <!-- Stats -->
    <div class="grid-4">
      <div class="stat-card">
        <div class="label">Total Leads</div>
        <div class="value">{summary.total}</div>
        <div class="sub">all time</div>
      </div>
      <div class="stat-card">
        <div class="label">High Urgency</div>
        <div class="value" style="color:#f97316">{summary.highUrgency}</div>
        <div class="sub">respond today</div>
      </div>
      <div class="stat-card">
        <div class="label">New Leads</div>
        <div class="value">{summary.byStage['new_lead'] ?? 0}</div>
        <div class="sub">needs review</div>
      </div>
      <div class="stat-card">
        <div class="label">Qualified</div>
        <div class="value" style="color:#4ade80">{summary.byStage['qualified'] ?? 0}</div>
        <div class="sub">in conversation</div>
      </div>
    </div>

    <!-- Pipeline breakdown -->
    <div class="two-col">
      <div class="panel">
        <div class="section-title">By Stage</div>
        {stageOrder.map(stage => {
          const count = summary.byStage[stage] ?? 0;
          const pct = summary.total > 0 ? (count / summary.total) * 100 : 0;
          return (
            <div class="bar-row">
              <div class="bar-label">{stage.replace('_', ' ')}</div>
              <div class="bar-track"><div class="bar-fill" style={`width:${pct}%`}></div></div>
              <div class="bar-count">{count}</div>
            </div>
          );
        })}
      </div>

      <div class="panel">
        <div class="section-title">By Service Interest</div>
        {intentOrder.map(intent => {
          const count = summary.byIntent[intent] ?? 0;
          const pct = summary.total > 0 ? (count / summary.total) * 100 : 0;
          return (
            <div class="bar-row">
              <div class="bar-label">{intent}</div>
              <div class="bar-track"><div class="bar-fill" style={`width:${pct}%; background:#6366f1`}></div></div>
              <div class="bar-count">{count}</div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Recent agent runs -->
    <div class="panel" style="margin-bottom: 48px;">
      <div class="section-title">Recent Agent Runs</div>
      {recentRuns.length === 0 ? (
        <p style="font-size:13px; color:#475569; margin:0; font-family:'JetBrains Mono',monospace;">No runs yet.</p>
      ) : (
        <table>
          <thead>
            <tr>
              <th>Trigger</th>
              <th>Agents</th>
              <th>Status</th>
              <th>Duration</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            {recentRuns.map(run => (
              <tr>
                <td class="mono" style="color:#e2e8f0">{run.trigger_type}</td>
                <td class="mono">{run.agents_invoked}</td>
                <td>
                  <span class={`badge ${run.status === 'success' ? 'badge-success' : run.status === 'failed' ? 'badge-failed' : 'badge-running'}`}>
                    {run.status}
                  </span>
                </td>
                <td class="mono">{formatDuration(run.duration_ms)}</td>
                <td class="mono">{formatDate(run.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</body>
</html>
