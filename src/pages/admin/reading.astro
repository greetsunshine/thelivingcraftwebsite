---
export const prerender = false;

import { queryReadingList, type ReadingItemRow } from '../../lib/db';

let items: ReadingItemRow[] = [];
let dbError = '';

try {
  items = await queryReadingList();
} catch (err) {
  dbError = err instanceof Error ? err.message : String(err);
}

const technical = items.filter((i) => i.category === 'technical');
const business  = items.filter((i) => i.category === 'business');

function formatRelative(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const days = Math.floor(diff / 86_400_000);
  if (days < 1) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 7) return `${days}d ago`;
  return `${Math.floor(days / 7)}w ago`;
}

function scoreBar(score: number): string {
  const pct = Math.round(score * 100);
  const color = score >= 0.9 ? '#4ade80' : score >= 0.7 ? '#facc15' : '#94a3b8';
  return `<span style="font-family:'JetBrains Mono',monospace;color:${color};font-size:12px">${pct}</span>`;
}

const statusColor: Record<string, string> = {
  unread:   '#818cf8',
  reading:  '#fbbf24',
  read:     '#4ade80',
  archived: '#64748b',
  dismissed:'#64748b',
};
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reading — Admin — The Living Craft</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: #0a0a0f; color: #e2e8f0; min-height: 100vh; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    header { border-bottom: 1px solid #1e293b; padding: 16px 0; }
    header .inner { display: flex; align-items: center; justify-content: space-between; }
    header h1 { font-size: 14px; font-weight: 600; color: #fff; margin: 0; }
    header nav { display: flex; gap: 24px; }
    header nav a { font-size: 13px; color: #94a3b8; text-decoration: none; }
    header nav a:hover, header nav a.active { color: #fff; }
    .page-header { margin: 32px 0 24px; }
    .page-title { font-size: 24px; font-weight: 700; color: #fff; margin: 0 0 4px; }
    .page-subtitle { font-size: 13px; color: #64748b; margin: 0; font-family: 'JetBrains Mono', monospace; }
    .category-group { margin-bottom: 40px; }
    .category-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #1e293b; }
    .category-title { font-size: 16px; font-weight: 600; color: #fff; margin: 0; }
    .category-count { font-size: 11px; font-family: 'JetBrains Mono', monospace; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; }
    .item-card { background: #16213e; border: 1px solid #1e293b; border-radius: 8px; padding: 14px 16px; margin-bottom: 8px; }
    .item-card:hover { border-color: #334155; }
    .item-header { display: flex; justify-content: space-between; gap: 12px; margin-bottom: 6px; }
    .item-title { font-size: 14px; font-weight: 600; color: #e2e8f0; margin: 0; flex: 1; }
    .item-title a { color: inherit; text-decoration: none; }
    .item-title a:hover { color: #818cf8; }
    .item-why { font-size: 13px; color: #94a3b8; line-height: 1.5; margin: 4px 0 8px; }
    .item-meta { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; font-size: 11px; font-family: 'JetBrains Mono', monospace; color: #475569; }
    .meta-badge { padding: 2px 7px; border-radius: 3px; border: 1px solid currentColor; background: transparent; text-transform: uppercase; letter-spacing: 0.04em; }
    .item-actions { display: flex; gap: 6px; align-items: flex-start; flex-shrink: 0; }
    .action-btn { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 8px; border-radius: 4px; border: 1px solid #334155; background: #0f1829; color: #94a3b8; cursor: pointer; text-transform: uppercase; letter-spacing: 0.04em; }
    .action-btn:hover { border-color: #4f46e5; color: #fff; }
    .action-btn.read:hover { border-color: #4ade80; color: #4ade80; }
    .action-btn.dismiss:hover { border-color: #f87171; color: #f87171; }
    .action-form { display: inline; margin: 0; padding: 0; }
    .empty-state { text-align: center; padding: 64px 24px; }
    .empty-state p { font-family: 'JetBrains Mono', monospace; color: #475569; font-size: 13px; }
    .error-banner { background: #2d0a0a; border: 1px solid #7f1d1d; border-radius: 8px; padding: 16px; color: #f87171; font-size: 13px; margin-bottom: 24px; font-family: 'JetBrains Mono', monospace; }
  </style>
</head>
<body>
  <header>
    <div class="container inner">
      <h1>The Living Craft <span class="mono" style="color:#4f46e5">/admin</span></h1>
      <nav>
        <a href="/admin/">Overview</a>
        <a href="/admin/leads/">Leads</a>
        <a href="/admin/tasks/">Tasks</a>
        <a href="/admin/reading/" class="active">Reading</a>
        <a href="/">← Site</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <div class="page-header">
      <h2 class="page-title">Reading List</h2>
      <p class="page-subtitle">{items.length} curated items · Updated Sunday nights by The Scribe</p>
    </div>

    {dbError && <div class="error-banner">DB error: {dbError}</div>}

    {items.length === 0 ? (
      <div class="empty-state">
        <p>Reading list is empty. Scribe's intelligence scan runs Sunday 22:00 UTC — or trigger it manually.</p>
      </div>
    ) : (
      <>
        {technical.length > 0 && (
          <div class="category-group">
            <div class="category-header">
              <h3 class="category-title">Technical Frontier</h3>
              <span class="category-count">{technical.length} items · building agentic systems</span>
            </div>
            {technical.map(item => (
              <div class="item-card">
                <div class="item-header">
                  <div style="flex:1;min-width:0">
                    <p class="item-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></p>
                    <p class="item-why">{item.why_it_matters}</p>
                    <div class="item-meta">
                      <span set:html={scoreBar(item.relevance_score)} />
                      {item.subcategory && <span class="meta-badge" style="color:#818cf8">{item.subcategory.replace('_', ' ')}</span>}
                      {item.source && <span>· {item.source}</span>}
                      {item.published_date && <span>· {item.published_date}</span>}
                      <span>· saved {formatRelative(item.created_at)}</span>
                      <span class="meta-badge" style={`color:${statusColor[item.status]}`}>{item.status}</span>
                    </div>
                  </div>
                  <div class="item-actions">
                    <form class="action-form" method="POST" action={`/api/admin/reading/${item.id}`}>
                      <input type="hidden" name="action" value="read" />
                      <button class="action-btn read" type="submit" title="Mark as read">✓ Read</button>
                    </form>
                    <form class="action-form" method="POST" action={`/api/admin/reading/${item.id}`}>
                      <input type="hidden" name="action" value="dismiss" />
                      <button class="action-btn dismiss" type="submit" title="Not interested">Dismiss</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {business.length > 0 && (
          <div class="category-group">
            <div class="category-header">
              <h3 class="category-title">Business Context</h3>
              <span class="category-count">{business.length} items · F500 buyer signals</span>
            </div>
            {business.map(item => (
              <div class="item-card">
                <div class="item-header">
                  <div style="flex:1;min-width:0">
                    <p class="item-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></p>
                    <p class="item-why">{item.why_it_matters}</p>
                    <div class="item-meta">
                      <span set:html={scoreBar(item.relevance_score)} />
                      {item.subcategory && <span class="meta-badge" style="color:#fbbf24">{item.subcategory.replace('_', ' ')}</span>}
                      {item.source && <span>· {item.source}</span>}
                      {item.published_date && <span>· {item.published_date}</span>}
                      <span>· saved {formatRelative(item.created_at)}</span>
                      <span class="meta-badge" style={`color:${statusColor[item.status]}`}>{item.status}</span>
                    </div>
                  </div>
                  <div class="item-actions">
                    <form class="action-form" method="POST" action={`/api/admin/reading/${item.id}`}>
                      <input type="hidden" name="action" value="read" />
                      <button class="action-btn read" type="submit" title="Mark as read">✓ Read</button>
                    </form>
                    <form class="action-form" method="POST" action={`/api/admin/reading/${item.id}`}>
                      <input type="hidden" name="action" value="dismiss" />
                      <button class="action-btn dismiss" type="submit" title="Not interested">Dismiss</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </>
    )}
  </div>
</body>
</html>
