---
export const prerender = false;

import { queryOpenTasks, type TaskRow, type TaskCategory } from '../../lib/db';

let tasks: TaskRow[] = [];
let dbError = '';

try {
  tasks = await queryOpenTasks();
} catch (err) {
  dbError = err instanceof Error ? err.message : String(err);
}

const priorityLabel: Record<number, string> = {
  1: 'DROP EVERYTHING',
  2: 'TODAY',
  3: 'THIS WEEK',
  4: 'NEXT WEEK',
  5: 'WHENEVER',
};
const priorityColor: Record<number, string> = {
  1: '#f87171',
  2: '#fb923c',
  3: '#facc15',
  4: '#60a5fa',
  5: '#64748b',
};
const categoryColor: Record<TaskCategory, string> = {
  lead_followup:   '#a5b4fc',
  outreach:        '#fbbf24',
  content_review:  '#86efac',
  learning:        '#67e8f9',
  pipeline_review: '#f472b6',
  manual:          '#94a3b8',
};
const creatorColor: Record<string, string> = {
  concierge: '#818cf8',
  scribe:    '#4ade80',
  marketer:  '#fbbf24',
  archivist: '#f472b6',
  owner:     '#94a3b8',
};

// Group by priority
const grouped: Record<number, TaskRow[]> = { 1: [], 2: [], 3: [], 4: [], 5: [] };
for (const t of tasks) grouped[t.priority].push(t);

function formatRelative(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const hours = Math.floor(diff / 3_600_000);
  if (hours < 1) return 'just now';
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tasks — Admin — The Living Craft</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: #0a0a0f; color: #e2e8f0; min-height: 100vh; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    header { border-bottom: 1px solid #1e293b; padding: 16px 0; }
    header .inner { display: flex; align-items: center; justify-content: space-between; }
    header h1 { font-size: 14px; font-weight: 600; color: #fff; margin: 0; }
    header nav { display: flex; gap: 24px; }
    header nav a { font-size: 13px; color: #94a3b8; text-decoration: none; }
    header nav a:hover, header nav a.active { color: #fff; }
    .page-header { margin: 32px 0 24px; }
    .page-title { font-size: 24px; font-weight: 700; color: #fff; margin: 0 0 4px; }
    .page-subtitle { font-size: 13px; color: #64748b; margin: 0; font-family: 'JetBrains Mono', monospace; }
    .priority-group { margin-bottom: 32px; }
    .priority-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #1e293b; }
    .priority-badge { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; }
    .priority-count { font-size: 12px; color: #475569; font-family: 'JetBrains Mono', monospace; }
    .task-card { background: #16213e; border: 1px solid #1e293b; border-radius: 8px; padding: 14px 16px; margin-bottom: 8px; display: flex; gap: 16px; align-items: flex-start; }
    .task-card:hover { border-color: #334155; }
    .task-main { flex: 1; min-width: 0; }
    .task-actions { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; flex-shrink: 0; }
    .action-row { display: flex; gap: 4px; }
    .action-btn { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 8px; border-radius: 4px; border: 1px solid #334155; background: #0f1829; color: #94a3b8; cursor: pointer; text-transform: uppercase; letter-spacing: 0.04em; }
    .action-btn:hover { border-color: #4f46e5; color: #fff; }
    .action-btn.done:hover { border-color: #4ade80; color: #4ade80; }
    .action-btn.dismiss:hover { border-color: #f87171; color: #f87171; }
    .action-form { display: inline; margin: 0; padding: 0; }
    .task-title { font-size: 14px; font-weight: 600; color: #e2e8f0; margin: 0 0 4px; }
    .task-desc { font-size: 12px; color: #64748b; margin: 0 0 6px; white-space: pre-wrap; }
    .task-meta { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; font-size: 11px; font-family: 'JetBrains Mono', monospace; color: #475569; }
    .meta-badge { padding: 2px 8px; border-radius: 3px; border: 1px solid currentColor; background: transparent; }
    .empty-state { text-align: center; padding: 64px 24px; }
    .empty-state p { font-family: 'JetBrains Mono', monospace; color: #475569; font-size: 13px; }
    .error-banner { background: #2d0a0a; border: 1px solid #7f1d1d; border-radius: 8px; padding: 16px; color: #f87171; font-size: 13px; margin-bottom: 24px; font-family: 'JetBrains Mono', monospace; }
  </style>
</head>
<body>
  <header>
    <div class="container inner">
      <h1>The Living Craft <span class="mono" style="color:#4f46e5">/admin</span></h1>
      <nav>
        <a href="/admin/">Overview</a>
        <a href="/admin/leads/">Leads</a>
        <a href="/admin/tasks/" class="active">Tasks</a>
        <a href="/">← Site</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <div class="page-header">
      <h2 class="page-title">Crew Queue</h2>
      <p class="page-subtitle">{tasks.length} open tasks · Concierge, Scribe, Marketer, Archivist</p>
    </div>

    {dbError && <div class="error-banner">DB error: {dbError}</div>}

    {tasks.length === 0 ? (
      <div class="empty-state">
        <p>No open tasks. Either the crew hasn't run yet, or you're caught up.</p>
      </div>
    ) : (
      [1, 2, 3, 4, 5].map(p => (
        grouped[p].length > 0 && (
          <div class="priority-group">
            <div class="priority-header">
              <span class="priority-badge" style={`color:${priorityColor[p]};border:1px solid ${priorityColor[p]};background:${priorityColor[p]}15`}>
                P{p} · {priorityLabel[p]}
              </span>
              <span class="priority-count">{grouped[p].length} task{grouped[p].length === 1 ? '' : 's'}</span>
            </div>
            {grouped[p].map(t => (
              <div class="task-card">
                <div class="task-main">
                  <p class="task-title">{t.title}</p>
                  {t.description && <p class="task-desc">{t.description}</p>}
                  <div class="task-meta">
                    <span class="meta-badge" style={`color:${categoryColor[t.category]}`}>{t.category.replace('_', ' ')}</span>
                    <span class="meta-badge" style={`color:${creatorColor[t.created_by] ?? '#94a3b8'}`}>by {t.created_by}</span>
                    <span>· {formatRelative(t.created_at)}</span>
                    {t.due_by && <span style="color:#fb923c">· due {new Date(t.due_by).toLocaleDateString()}</span>}
                    {t.related_url && <a href={t.related_url} style="color:#4f46e5;text-decoration:none">→ open</a>}
                  </div>
                </div>
                <div class="task-actions">
                  <div class="action-row">
                    <form class="action-form" method="POST" action={`/api/admin/tasks/${t.id}`}>
                      <input type="hidden" name="action" value="done" />
                      <button class="action-btn done" type="submit" title="Mark done">✓ Done</button>
                    </form>
                    <form class="action-form" method="POST" action={`/api/admin/tasks/${t.id}`}>
                      <input type="hidden" name="action" value="dismiss" />
                      <button class="action-btn dismiss" type="submit" title="Dismiss task">Dismiss</button>
                    </form>
                  </div>
                  <div class="action-row">
                    <form class="action-form" method="POST" action={`/api/admin/tasks/${t.id}`}>
                      <input type="hidden" name="action" value="snooze_1d" />
                      <button class="action-btn" type="submit" title="Hide until tomorrow">+1d</button>
                    </form>
                    <form class="action-form" method="POST" action={`/api/admin/tasks/${t.id}`}>
                      <input type="hidden" name="action" value="snooze_1w" />
                      <button class="action-btn" type="submit" title="Hide for a week">+1w</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )
      ))
    )}
  </div>
</body>
</html>
