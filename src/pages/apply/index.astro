---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Apply"
  description="Apply to the next cohort of The Living Craft's agent architecture programme for senior technical leaders."
>

<!-- ─── HERO ──────────────────────────────────────────────── -->
<section
  class="relative py-28 overflow-hidden"
  style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 60%);"
>
  <div class="absolute inset-0 opacity-[0.04]"
       style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>

  <div class="relative container mx-auto px-6 max-w-3xl">
    <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Application</p>
    <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 leading-tight">
      Apply to the cohort
    </h1>
    <p class="text-xl text-gray-400 max-w-2xl leading-relaxed">
      Three questions. No cover letter, no CV. We want to know what you're building
      and what's hard about it.
    </p>
  </div>
</section>


<!-- ─── APPLICATION FORM ──────────────────────────────────── -->
<section class="py-24 bg-dark-primary">
  <div class="container mx-auto px-6 max-w-2xl">

    <form
      name="cohort-application"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-10"
    >
      <input type="hidden" name="form-name" value="cohort-application" />
      <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

      <!-- Question 1 -->
      <div>
        <label for="role" class="block text-white font-semibold text-lg mb-2">
          What's your current role?
        </label>
        <p class="text-gray-400 text-sm mb-4">
          Title, company (or stage), and how long you've been in this seat.
        </p>
        <input
          type="text"
          id="role"
          name="role"
          required
          placeholder="e.g. Staff Engineer at a Series C fintech, 2 years"
          class="w-full px-5 py-4 rounded-xl border border-gray-700/60 bg-dark-card text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors text-sm"
        />
      </div>

      <!-- Question 2 -->
      <div>
        <label for="shipping" class="block text-white font-semibold text-lg mb-2">
          What are you trying to ship?
        </label>
        <p class="text-gray-400 text-sm mb-4">
          The agent system, product, or capability you're working toward. Doesn't need to be started yet.
        </p>
        <textarea
          id="shipping"
          name="shipping"
          required
          rows="4"
          placeholder="e.g. An internal agent that triages and routes customer support tickets using our knowledge base. We've prototyped but can't get accuracy above 70%."
          class="w-full px-5 py-4 rounded-xl border border-gray-700/60 bg-dark-card text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors text-sm resize-none"
        ></textarea>
      </div>

      <!-- Question 3 -->
      <div>
        <label for="problem" class="block text-white font-semibold text-lg mb-2">
          What's one architecture problem you've been wrestling with?
        </label>
        <p class="text-gray-400 text-sm mb-4">
          The kind of problem where you've read three blog posts and gotten three different answers.
        </p>
        <textarea
          id="problem"
          name="problem"
          required
          rows="4"
          placeholder="e.g. Whether to use a single orchestrator agent or a multi-agent pipeline, and how to handle failures gracefully when an agent in the chain hallucinates."
          class="w-full px-5 py-4 rounded-xl border border-gray-700/60 bg-dark-card text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors text-sm resize-none"
        ></textarea>
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-white font-semibold text-lg mb-2">
          Email
        </label>
        <p class="text-gray-400 text-sm mb-4">
          Where we'll reach you if there's a fit.
        </p>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="you@company.com"
          class="w-full px-5 py-4 rounded-xl border border-gray-700/60 bg-dark-card text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors text-sm"
        />
      </div>

      <!-- Submit -->
      <div class="pt-4">
        <button
          type="submit"
          class="group inline-flex items-center gap-2.5 px-10 py-5 rounded-xl text-white font-bold text-base transition-all duration-200 shadow-2xl shadow-accent/30 hover:shadow-accent/50 cursor-pointer"
          style="background: linear-gradient(135deg, #4f46e5, #6366f1);"
        >
          Submit application
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </form>

    <!-- What happens next -->
    <div class="mt-16 p-6 rounded-2xl border border-gray-700/40 bg-dark-card">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">What happens next</p>
      <div class="space-y-3 text-gray-400 text-sm">
        <p>1. You submit. Takes two minutes.</p>
        <p>2. I read every application personally. Not a funnel — a read.</p>
        <p>3. If there's a fit, I'll email you within 48 hours to set up a 15-minute call.</p>
        <p>4. If it's not the right time, I'll tell you that too. No ghosting.</p>
      </div>
    </div>

  </div>
</section>

</BaseLayout>
