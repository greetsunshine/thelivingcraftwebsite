---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const tagColors: Record<string, string> = {
  violet:  '#818cf8',
  pink:    '#f472b6',
  cyan:    '#22d3ee',
  emerald: '#34d399',
  amber:   '#fbbf24',
};

const dateStr = post.data.date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: 'Sunil Mathew' },
  publisher: { '@type': 'Organization', name: 'The Living Craft' },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.ogImage}
  schema={blogPostSchema}
>

  <style>
    .prose h2 {
      color: white;
      font-size: 1.5rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      line-height: 1.3;
    }
    .prose h3 {
      color: white;
      font-size: 1.125rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }
    .prose p {
      color: #d1d5db;
      font-size: 0.9375rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
    }
    .prose ul, .prose ol {
      color: #d1d5db;
      font-size: 0.9375rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }
    .prose li { margin-bottom: 0.5rem; }
    .prose strong { color: white; }
    .prose em { color: #a0a0c0; }
    .prose a { color: #818cf8; text-decoration: underline; text-decoration-color: rgba(129,140,248,0.4); }
    .prose a:hover { color: white; }
    .prose blockquote {
      border-left: 2px solid rgba(79,70,229,0.6);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      color: #9ca3af;
      font-style: italic;
    }
    .prose code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125rem;
      background: rgba(79,70,229,0.1);
      border: 1px solid rgba(79,70,229,0.2);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      color: #a5b4fc;
    }
    .prose pre {
      background: #0d0d18;
      border: 1px solid rgba(75,85,99,0.4);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
      overflow-x: auto;
    }
    .prose pre code {
      background: none;
      border: none;
      padding: 0;
      color: #d1d5db;
      font-size: 0.8125rem;
    }
    .prose hr {
      border: none;
      border-top: 1px solid rgba(75,85,99,0.3);
      margin: 2.5rem 0;
    }
  </style>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative py-20 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 65%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative container mx-auto px-6 max-w-3xl">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-xs font-mono text-gray-400 mb-6">
        <a href="/blog/" class="hover:text-gray-400 transition-colors">Blog</a>
        <span>›</span>
        <span class="text-gray-400" style={`color: ${tagColors[post.data.tagColor]};`}>{post.data.tag}</span>
      </div>

      <!-- Tag + read time -->
      <div class="flex items-center gap-3 mb-5">
        <span class="px-2.5 py-1 text-xs font-mono rounded-md"
              style={`background: ${tagColors[post.data.tagColor]}18; color: ${tagColors[post.data.tagColor]};`}>
          {post.data.tag}
        </span>
        <span class="text-gray-400 text-xs font-mono">{post.data.readTime} read</span>
        <span class="text-gray-400 text-xs font-mono ml-auto">{dateStr}</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-white mb-5 leading-snug">
        {post.data.title}
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed">{post.data.description}</p>
    </div>
  </section>


  <!-- ─── ARTICLE BODY ─────────────────────────────────────── -->
  <article class="bg-dark-primary py-16">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>


  <!-- ─── BACK + CTA ───────────────────────────────────────── -->
  <section class="bg-dark-secondary py-16">
    <div class="container mx-auto px-6 max-w-3xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <a href="/blog/"
         class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors text-sm font-mono">
        ← All posts
      </a>
      <a href="/contact/"
         class="inline-flex items-center gap-2 px-6 py-3 text-white font-semibold rounded-xl text-sm transition-opacity hover:opacity-90"
         style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
        Work with me →
      </a>
    </div>
  </section>

</BaseLayout>
