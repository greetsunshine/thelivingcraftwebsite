---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const rest = allPosts.filter(p => p.id !== featured.id);

const tagColors: Record<string, string> = {
  violet:  'rgba(79,70,229,0.15)',
  pink:    'rgba(236,72,153,0.15)',
  cyan:    'rgba(6,182,212,0.15)',
  emerald: 'rgba(16,185,129,0.15)',
  amber:   'rgba(245,158,11,0.15)',
};
const tagText: Record<string, string> = {
  violet:  '#818cf8',
  pink:    '#f472b6',
  cyan:    '#22d3ee',
  emerald: '#34d399',
  amber:   '#fbbf24',
};
---

<BaseLayout
  title="Blog"
  description="Practitioner-grade writing on Agentic AI architecture, leadership, and ultra fast learning for senior technical leaders."
>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative py-20 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 65%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative container mx-auto px-6">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Blog</p>
      <h1 class="text-5xl font-bold text-white mb-5 max-w-2xl leading-tight">
        Writing for senior technical leaders
      </h1>
      <p class="text-gray-400 text-lg max-w-xl leading-relaxed">
        Architecture decisions, leadership frameworks, and ultra fast learning —
        everything usable the day you read it.
      </p>
    </div>
  </section>


  <!-- ─── FEATURED POST ────────────────────────────────────── -->
  <section class="bg-dark-primary py-16">
    <div class="container mx-auto px-6">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-8">Featured</p>
      <a href={`/blog/${featured.id}/`}
         class="group grid grid-cols-1 lg:grid-cols-5 gap-8 p-8 bg-dark-card border border-gray-700/40 hover:border-accent/30 rounded-2xl transition-all duration-300">

        <div class="lg:col-span-5 flex items-center gap-3 mb-2">
          <span class="px-2.5 py-1 text-xs font-mono rounded-md"
                style={`background: ${tagColors[featured.data.tagColor]}; color: ${tagText[featured.data.tagColor]};`}>
            {featured.data.tag}
          </span>
          <span class="text-gray-600 text-xs font-mono">
            {featured.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
          </span>
          <span class="text-gray-600 text-xs font-mono ml-auto">{featured.data.readTime} read</span>
        </div>

        <div class="lg:col-span-3">
          <h2 class="text-2xl md:text-3xl font-bold text-white group-hover:text-accent transition-colors duration-200 leading-snug mb-4">
            {featured.data.title}
          </h2>
          <p class="text-gray-400 leading-relaxed">{featured.data.description}</p>
        </div>

        <div class="lg:col-span-2 flex items-end justify-end">
          <span class="text-accent text-sm font-medium group-hover:translate-x-1 transition-transform duration-200 inline-block">
            Read article →
          </span>
        </div>
      </a>
    </div>
  </section>


  <!-- ─── POST GRID ─────────────────────────────────────────── -->
  {rest.length > 0 && (
    <section class="bg-dark-primary pb-24">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map(p => (
            <a href={`/blog/${p.id}/`}
               class="group flex flex-col bg-dark-card border border-gray-700/40 hover:border-accent/30 rounded-2xl overflow-hidden transition-all duration-300">

              <div class="h-1 w-full" style={`background: ${tagText[p.data.tagColor]}; opacity: 0.6;`}></div>

              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2.5 mb-5">
                  <span class="px-2 py-0.5 text-[10px] font-mono rounded"
                        style={`background: ${tagColors[p.data.tagColor]}; color: ${tagText[p.data.tagColor]};`}>
                    {p.data.tag}
                  </span>
                  <span class="text-gray-600 text-xs font-mono">
                    {p.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                  </span>
                </div>

                <h3 class="text-white font-bold text-base leading-snug mb-3 group-hover:text-accent/90 transition-colors duration-200 flex-1">
                  {p.data.title}
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed mb-6">{p.data.description}</p>

                <div class="flex items-center justify-between pt-4 border-t border-gray-700/40">
                  <span class="text-gray-600 text-xs font-mono">{p.data.readTime} read</span>
                  <span class="text-accent text-xs font-medium group-hover:translate-x-0.5 transition-transform duration-200 inline-block">
                    Read →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ─── NEWSLETTER ───────────────────────────────────────── -->
  <section class="bg-dark-secondary py-20">
    <div class="container mx-auto px-6 max-w-xl text-center">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Stay sharp</p>
      <h2 class="text-3xl font-bold text-white mb-4">New writing, when it's ready.</h2>
      <p class="text-gray-400 text-sm mb-8">
        No cadence commitments, no AI-generated filler. Just new articles when they're worth sending.
      </p>
      <form
        name="newsletter"
        method="POST"
        data-netlify="true"
        class="flex gap-3 max-w-sm mx-auto"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 text-sm text-white rounded-xl outline-none transition-colors"
          style="background: #0d0d14; border: 1px solid rgba(75,85,99,0.4);"
        />
        <button type="submit"
                class="px-5 py-3 text-white text-sm font-semibold rounded-xl transition-opacity hover:opacity-90 flex-shrink-0"
                style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
          Subscribe
        </button>
      </form>
    </div>
  </section>

</BaseLayout>
