---
import CaioLayout from '../layouts/CaioLayout.astro';
import { APPLY_ACCESS_KEY, CONTACT_EMAIL } from '../data/site';

// Static, board-facing landing page for the Fractional Chief AI Officer practice.
// Sibling surface to the cohort page (/) — same design system, brand-neutral copy.
const title = 'Fractional Chief AI Officer — Sunil Mathew';
const description =
  'An embedded AI executive — part-time, accountable for outcomes. I own your AI strategy, governance, and roadmap, get your first use cases into production, and leave your team able to run it.';
---

<CaioLayout title={title} description={description} canonical="https://learning.thelivingcraft.ai/caio">
  <!-- 00 HERO -->
  <section class="hero" id="top" style="border-top:0">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow"><span class="num">00</span> An embedded AI executive — part-time, accountable for outcomes · India</span>
        <h1>From pilot purgatory to <em>governed production.</em></h1>
        <p class="credential">
          I own your AI strategy, governance, and roadmap, get your <strong>first use cases into production</strong>,
          and leave your team able to run it — without the cost or wait of a full-time Chief AI Officer.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="#contact">Book a discovery call <span class="arrow">→</span></a>
          <a class="btn btn-ghost" href="/assessment">Start with an AI Readiness Assessment</a>
        </div>
        <p class="hero-note">26 years at Google · Amazon · Walmart — and building agentic AI now.</p>
      </div>
      <div class="portrait">
        <div class="frame">
          <img src="/sunil-profile.jpg" alt="Sunil Mathew" />
          <div class="warm"></div>
        </div>
        <div class="tag"><b>Sunil Mathew</b>Fractional CAIO · ex-Google, Amazon, Walmart</div>
      </div>
    </div>
  </section>

  <!-- PROOF BAR -->
  <div class="proofbar">
    <div class="wrap inner">
      <span class="label">26 years, shipped at</span>
      <span class="logo">Google</span>
      <span class="logo">Amazon</span>
      <span class="logo">Walmart</span>
      <span class="logo">Agentic AI, now</span>
    </div>
  </div>

  <!-- 01 THE PROBLEM -->
  <section id="problem">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow"><span class="num">01</span> The leadership gap</span>
        <h2>You don't have an AI tooling problem. You have an AI <em>ownership</em> problem.</h2>
      </div>
      <div class="prose">
        <p>The signs are familiar. Pilots that demo well and never ship. AI tools spreading through teams with no one watching the data or the risk. A CTO already at capacity, now expected to add AI strategy on top. Your best engineers quietly leaving because nothing they build on actually reaches customers. And a board asking where the return is.</p>
        <p>None of this is solved by another platform subscription. It's solved by one senior person holding the mandate — owning the strategy, the governance, the build-vs-buy calls, and the accountability for getting something real into production.</p>
        <p class="prose-emph">That's the seat I fill.</p>
      </div>
    </div>
  </section>

  <!-- 02 WHAT I OWN -->
  <section id="own">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow"><span class="num">02</span> What a fractional CAIO owns</span>
        <h2>The whole AI agenda — <em>not a corner of it.</em></h2>
      </div>
      <div class="cards3">
        <div class="card">
          <div class="k">// strategy</div>
          <h3>Strategy &amp; roadmap</h3>
          <p>Your AI use cases sequenced by impact and readiness, aligned to where the business actually makes money.</p>
        </div>
        <div class="card">
          <div class="k">// governance</div>
          <h3>Governance &amp; risk</h3>
          <p>A governance model that turns shadow AI into sanctioned AI — mapped to the DPDP Act and your regulator (IRDAI, RBI, SEBI), and to global frameworks where you operate across borders.</p>
        </div>
        <div class="card">
          <div class="k">// decisions</div>
          <h3>Build-vs-buy &amp; vendors</h3>
          <p>The decisions that are expensive to reverse, made deliberately and defended.</p>
        </div>
        <div class="card">
          <div class="k">// delivery</div>
          <h3>First use cases into production</h3>
          <p>Not more pilots. Two to three that ship, with evals and cost you can stand behind.</p>
        </div>
        <div class="card">
          <div class="k">// board</div>
          <h3>Board &amp; leadership reporting</h3>
          <p>Translating AI from anxiety into a plan your board can fund and track.</p>
        </div>
        <div class="card">
          <div class="k">// handover</div>
          <h3>Capability transfer</h3>
          <p>Building the operating model and the literacy so your team carries it after I step back.</p>
        </div>
      </div>
      <blockquote class="quote-light">A consultant hands you a deck and leaves. I join the operating rhythm — and I'm accountable for whether the metric moves.</blockquote>
    </div>
  </section>

  <!-- 03 WHAT I'M NOT -->
  <section id="lines" class="inaugural">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow"><span class="num">03</span> Where the lines are</span>
        <h2>Clear decision rights, from day one.</h2>
      </div>
      <div class="compare">
        <div class="row">
          <div class="vs">vs your <span>CTO</span></div>
          <p>Your CTO runs the engineering organisation. I own AI strategy and governance across the business and sit above delivery. We define decision rights at the start; I make the CTO's life easier, not harder.</p>
        </div>
        <div class="row">
          <div class="vs">vs a <span>full-time CAIO</span></div>
          <p>Same accountability and board-facing ownership, a fraction of the time and cost — and an engagement designed to phase out, not to become a permanent dependency.</p>
        </div>
        <div class="row">
          <div class="vs">vs an <span>AI agency</span></div>
          <p>They execute scopes. I own outcomes — and I'll tell you when the answer is <em>don't build this.</em></p>
        </div>
      </div>
    </div>
  </section>

  <!-- 04 WHY ME — dark centerpiece -->
  <section class="experience" id="maker">
    <div class="wrap">
      <div class="sec-head" style="margin-bottom:0">
        <span class="eyebrow"><span class="num">04</span> The maker</span>
        <h2>I've shipped this at the scale where mistakes are <em>expensive</em> — and I'm in the trenches now.</h2>
      </div>

      <div class="statband">
        <div class="stat"><div class="big">26<span>+</span></div><div class="cap">Years building software</div></div>
        <div class="stat"><div class="big">3</div><div class="cap">Fortune-100s · Google, Amazon, Walmart</div></div>
        <div class="stat"><div class="big">100M<span>+</span></div><div class="cap">Users served by systems built</div></div>
        <div class="stat"><div class="big">150</div><div class="cap">Engineers led across geographies</div></div>
      </div>

      <div class="story">
        <div class="maker-portrait">
          <div class="mframe"><img src="/sunil-bw.jpg" alt="Sunil Mathew" /></div>
          <div class="mcap">Sunil Mathew · Bengaluru, India</div>
        </div>
        <div>
          <p>I'm <strong>Sunil Mathew</strong>. Twenty-six years building and leading engineering at three Fortune-100s — <strong>Google, Amazon, and Walmart</strong> — on systems serving up to <strong>100M+ users</strong>, leading teams of up to 150 across the US, UK, China, and India.</p>
          <p>At Google I shipped a Generative-AI product and ran a platform at <strong>~31 billion executions a week</strong>. At Amazon I re-architected Prime's membership core. At Walmart I modernised <strong>300+ products</strong> from legacy into microservices and stood up AI and data-science capability. Today I lead <strong>agentic-AI</strong> work — multi-agent orchestration, RAG, evals, LLM-Ops — and I'm building an agentic-AI product of my own, so my judgment is current, not a memory.</p>
          <div class="pullquote">"The rare part for this role: I've done both the executive strategy and the production delivery — and I teach this craft to senior engineers, so transferring capability to your team isn't an afterthought. It's how I work."</div>
          <p style="margin-top:24px"><a href="/" class="link-ochre">See how I teach the craft — The Living Craft <span class="arrow">→</span></a></p>
          <div class="signature">— Sunil Mathew</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 05 HOW IT WORKS -->
  <section id="engagement">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow"><span class="num">05</span> The engagement</span>
        <h2>A 90-day spine, then we go where the <em>agenda</em> goes.</h2>
      </div>
      <div class="phases">
        <div class="phase">
          <div class="pk"><span class="pn">Phase 1</span><span class="pw">Weeks 1–4</span></div>
          <h4>Assess</h4>
          <p>Readiness, roadmap, governance foundation. If we've already done the AI Readiness Assessment, we start here with a head start — and the assessment fee is credited.</p>
        </div>
        <div class="phase">
          <div class="pk"><span class="pn">Phase 2</span><span class="pw">Months 2–3</span></div>
          <h4>Operationalise</h4>
          <p>Governance live, vendors decided, first use cases moving into production with evals in place.</p>
        </div>
        <div class="phase">
          <div class="pk"><span class="pn">Phase 3</span><span class="pw">Ongoing</span></div>
          <h4>Enable</h4>
          <p>Capability transfer, operating-model documentation, and a clear path to either a leaner advisory cadence or your own full-time hire when scope justifies it.</p>
        </div>
      </div>
      <p class="note-line">Most engagements run 6–18 months — two to three days a week early on, tapering as your team takes the wheel.</p>
    </div>
  </section>

  <!-- 06 ENGAGEMENT TIERS -->
  <section id="tiers">
    <div class="wrap">
      <div class="sec-head" style="text-align:center;margin:0 auto 48px">
        <span class="eyebrow" style="justify-content:center"><span class="num">06</span> Ways to work together</span>
        <h2>Three ways in.</h2>
      </div>
      <!-- PRICING — ALL FIGURES ARE PLACEHOLDERS / STARTING ANCHORS. Flag for review before publishing. -->
      <div class="tiers">
        <div class="tier">
          <div class="tname">Advisory</div>
          <div class="tdays">~2 days / month</div>
          <p>Board cadence, governance oversight, and decision support for a team that's already moving.</p>
          <div class="tprice">From ₹1,50,000<small>/ month</small></div>
          <a class="btn btn-ghost tcta" href="#contact">Enquire <span class="arrow">→</span></a>
        </div>
        <div class="tier feature">
          <div class="badge">Most common</div>
          <div class="tname">Embedded</div>
          <div class="tdays">~1 day / week</div>
          <p>Roadmap ownership plus getting your first use cases into production.</p>
          <div class="tprice">From ₹3,50,000<small>/ month</small></div>
          <a class="btn btn-primary tcta" href="#contact">Enquire <span class="arrow">→</span></a>
        </div>
        <div class="tier">
          <div class="tname">Transformation</div>
          <div class="tdays">2–3 days / week</div>
          <p>Full ownership: build the function, the governance, and the team from the ground up.</p>
          <div class="tprice">From ₹6,00,000<small>/ month</small></div>
          <a class="btn btn-ghost tcta" href="#contact">Enquire <span class="arrow">→</span></a>
        </div>
      </div>
      <p class="fineprint">90-day minimum. Payment plans available. Most engagements begin with an <a href="/assessment" class="ftext-link">AI Readiness Assessment</a>.</p>
    </div>
  </section>

  <!-- 07 START HERE — contact -->
  <section class="final" id="contact">
    <div class="wrap">
      <span class="eyebrow" style="justify-content:center"><span class="num">07</span> The first step</span>
      <h2>Start with a <em>diagnosis</em>, not a contract.</h2>
      <p class="lead">The cleanest way in is the <a href="/assessment" class="ftext-link">AI Readiness Assessment</a> — two to three weeks, a fixed fee, and a board-ready roadmap you own regardless of what you do next. If you bring me on to drive it, the fee is credited toward your first month.</p>

      <form id="contactForm" class="apply-form">
        <input type="hidden" name="access_key" value={APPLY_ACCESS_KEY} />
        <input type="hidden" name="subject" value="New enquiry — Fractional CAIO" />
        <input type="hidden" name="from_name" value="Fractional CAIO — thelivingcraft.ai" />
        <!-- honeypot -->
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

        <div class="form-grid">
          <label>Name<input name="name" type="text" required autocomplete="name" /></label>
          <label>Work email<input name="email" type="email" required autocomplete="email" /></label>
          <label>Title<input name="role" type="text" placeholder="e.g. CEO, CTO, Board member" /></label>
          <label>Company<input name="company" type="text" /></label>
          <label class="full">What brings you here?
            <select name="intent">
              <option value="Discovery call">Book a discovery call</option>
              <option value="AI Readiness Assessment">Start with an AI Readiness Assessment</option>
              <option value="Advisory tier">Advisory engagement (~2 days / month)</option>
              <option value="Embedded tier">Embedded engagement (~1 day / week)</option>
              <option value="Transformation tier">Transformation engagement (2–3 days / week)</option>
            </select>
          </label>
          <label class="full">Where are you with AI today?
            <textarea name="message" rows="4" placeholder="A few sentences on where you are — pilots stuck, governance gaps, a board asking for a plan, or a use case you need in production."></textarea>
          </label>
        </div>

        <button class="btn btn-primary" type="submit">
          Send enquiry <span class="arrow">→</span>
        </button>
        <p class="form-status" id="formStatus" aria-live="polite"></p>
        <p class="form-alt">Prefer email? <a href={`mailto:${CONTACT_EMAIL}?subject=Fractional%20CAIO%20%E2%80%94%20Enquiry`}>Write to me directly →</a></p>
      </form>

      <p class="closing-line">You don't need a $400K hire to get serious about AI. You need someone who's done it to own it for a while — and then hand it back.</p>
    </div>
  </section>

  <script is:inline>
    (function () {
      var f = document.getElementById('contactForm');
      if (!f) return;
      var status = document.getElementById('formStatus');
      f.addEventListener('submit', async function (e) {
        e.preventDefault();
        var key = f.querySelector('input[name="access_key"]').value;
        if (!key || key.indexOf('REPLACE_WITH') === 0) {
          status.textContent = 'Please email apply@thelivingcraft.ai in the meantime.';
          status.className = 'form-status err';
          return;
        }
        status.textContent = 'Sending…';
        status.className = 'form-status';
        try {
          var res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(f),
          });
          var json = await res.json();
          if (json.success) {
            f.reset();
            f.querySelector('.form-grid').style.display = 'none';
            f.querySelector('button[type="submit"]').style.display = 'none';
            status.textContent = 'Thank you — your enquiry is in. I read every one personally and will reply by email.';
            status.className = 'form-status ok';
          } else {
            status.textContent = 'Something went wrong. Please email apply@thelivingcraft.ai.';
            status.className = 'form-status err';
          }
        } catch (err) {
          status.textContent = 'Network error. Please email apply@thelivingcraft.ai.';
          status.className = 'form-status err';
        }
      });
    })();
  </script>
</CaioLayout>

<style>
  /* ---- CAIO-specific components (built on the shared craft tokens) ---- */

  /* wordmark descriptor */
  .wordmark-sub{
    font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;
    color:var(--ink-faint);border-left:1px solid var(--line-strong);padding-left:10px;margin-left:2px;font-weight:400;
  }
  @media(max-width:520px){.wordmark-sub{display:none}}

  /* problem prose */
  .prose{max-width:62ch}
  .prose p{font-size:18px;color:var(--ink-soft);margin-bottom:22px}
  .prose .prose-emph{font-family:'Fraunces',serif;font-style:italic;font-size:24px;color:var(--ink);margin-top:4px}

  /* light pull-quote (dark version lives in global .pullquote) */
  .quote-light{
    font-family:'Fraunces',serif;font-style:italic;font-size:clamp(22px,2.6vw,30px);line-height:1.4;
    color:var(--ink);border-left:2px solid var(--clay);padding-left:26px;max-width:58ch;margin:52px 0 0;
  }

  /* comparison rows ("what I'm not") */
  .compare{display:flex;flex-direction:column}
  .compare .row{
    display:grid;grid-template-columns:.45fr 1fr;gap:32px;align-items:start;
    padding:26px 0;border-bottom:1px solid var(--line);
  }
  .compare .row:first-child{border-top:1px solid var(--line)}
  .compare .vs{font-family:'Fraunces',serif;font-size:22px;font-weight:420;color:var(--ink-soft);line-height:1.2}
  .compare .vs span{color:var(--ink);display:block;font-size:24px}
  .compare .row p{font-size:16.5px;color:var(--ink-soft);max-width:64ch}
  .compare .row p em{font-style:italic;color:var(--clay)}
  @media(max-width:760px){.compare .row{grid-template-columns:1fr;gap:10px}.compare .vs span{display:inline}}

  /* inline text link */
  .ftext-link{color:var(--clay);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px;text-decoration-color:var(--line-strong)}
  .ftext-link:hover{text-decoration-color:var(--clay)}

  /* dark-section helper link */
  .link-ochre{color:var(--ochre);font-weight:500;display:inline-flex;align-items:center;gap:8px}
  .link-ochre .arrow{transition:transform .22s ease}
  .link-ochre:hover .arrow{transform:translateX(4px)}

  /* phases (3-phase arc) */
  .phases{
    display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
    background:var(--line);border:1px solid var(--line);border-radius:3px;overflow:hidden;
  }
  .phase{background:var(--surface);padding:34px 30px;position:relative}
  .phase .pk{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px}
  .phase .pn{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--clay)}
  .phase .pw{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ink-faint);letter-spacing:.08em}
  .phase h4{font-size:22px;font-weight:440;margin-bottom:10px}
  .phase p{font-size:14.5px;color:var(--ink-soft)}
  @media(max-width:760px){.phases{grid-template-columns:1fr}}
  .note-line{margin-top:28px;font-size:14px;color:var(--ink-faint);font-family:'JetBrains Mono',monospace;letter-spacing:.02em}

  /* engagement tiers */
  .tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:stretch}
  .tier{
    background:var(--surface);border:1px solid var(--line);border-radius:3px;
    padding:36px 30px 32px;display:flex;flex-direction:column;position:relative;transition:.22s;
  }
  .tier:hover{transform:translateY(-2px);border-color:var(--line-strong)}
  .tier.feature{border-color:var(--clay);box-shadow:0 0 0 1px var(--clay)}
  .tier .badge{
    position:absolute;top:-11px;left:30px;background:var(--clay);color:#FBF7EE;
    font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;
    padding:5px 12px;border-radius:2px;
  }
  .tier .tname{font-family:'Fraunces',serif;font-size:26px;font-weight:420}
  .tier .tdays{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.06em;color:var(--clay);margin:6px 0 18px}
  .tier p{font-size:15px;color:var(--ink-soft);flex:1}
  .tier .tprice{font-family:'Fraunces',serif;font-size:30px;font-weight:360;color:var(--ink);margin:24px 0 22px}
  .tier .tprice small{font-family:'Inter',sans-serif;font-size:14px;color:var(--ink-faint);margin-left:6px}
  .tier .tcta{justify-content:center;width:100%}
  @media(max-width:820px){.tiers{grid-template-columns:1fr}}
  .fineprint{margin-top:30px;text-align:center;font-size:13.5px;color:var(--ink-faint);max-width:64ch;margin-left:auto;margin-right:auto}

  /* closing line under the form */
  .closing-line{
    max-width:54ch;margin:44px auto 0;font-family:'Fraunces',serif;font-style:italic;
    font-size:clamp(20px,2.4vw,26px);line-height:1.4;color:var(--ink);
  }

  /* ---- print: one-page leave-behind ---- */
  @media print{
    header.nav,footer.site,.hero-cta,#contact form,.proofbar,.tier .tcta{display:none!important}
    section{padding:24px 0;border-top:1px solid #ccc;page-break-inside:avoid}
    body{font-size:12px;background:#fff}
    .experience{background:#fff;color:#000}
    .experience h2,.experience .big,.story p strong{color:#000}
    .story p,.stat .cap{color:#333}
    .pullquote{color:#000;border-color:#999}
  }
</style>
