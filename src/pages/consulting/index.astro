---
import BaseLayout from '../../layouts/BaseLayout.astro';

const engagements = [
  {
    n: '01',
    title: 'Governance Framework Design',
    desc: 'Build the policies, review processes, and risk controls for AI deployment at scale.',
    deliverable: 'Governance playbook',
    ufl: 'Team builds competence during the engagement — not after it. Working draft by end of week 2.',
    detail: 'Policies · Review checkpoints · Risk classification · Incident playbooks',
    color: '#4f46e5',
    source: 'consulting-governance',
  },
  {
    n: '02',
    title: 'ROI Assessment & Business Case',
    desc: 'Quantify the value of AI initiatives with a defensible model your board will actually fund.',
    deliverable: 'Board-ready ROI analysis',
    ufl: 'Finance and engineering aligned in a single structured session — not sequential email threads.',
    detail: 'Cost model · Value drivers · Risk-adjusted scenarios · Sensitivity analysis',
    color: '#06b6d4',
    source: 'consulting-roi',
  },
  {
    n: '03',
    title: 'Agentic AI Adoption Strategy',
    desc: 'Sequenced roadmap from current state to production AI, with org change management built in.',
    deliverable: '90-day adoption plan',
    ufl: 'Rapid feedback loop: checkpoint at day 30, course-correct before day 90.',
    detail: 'Current-state assessment · Capability gaps · Sequencing · Change management',
    color: '#10b981',
    source: 'consulting-adoption',
  },
];

const processSteps = [
  { n: '1', label: 'Discovery call',     sub: '30 min · no pitch' },
  { n: '2', label: 'Scoping doc',         sub: 'Shared before engagement starts' },
  { n: '3', label: 'Engagement',          sub: 'With embedded learning milestones' },
  { n: '4', label: 'Deliverable + retro', sub: 'Handoff and retrospective' },
];
---

<BaseLayout
  title="Consulting"
  description="Agentic AI consulting for organisations — governance frameworks, ROI assessment, and adoption strategy built with your team using rapid org learning loops."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Agentic AI Consulting',
    description: 'Governance frameworks, ROI models, and adoption strategy — built with your team using rapid learning loops.',
    url: 'https://thelivingcraft.ai/consulting/',
    provider: { '@type': 'Organization', name: 'The Living Craft', url: 'https://thelivingcraft.ai' },
    serviceType: 'AI Strategy Consulting',
    areaServed: 'Worldwide',
  }}
>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative py-28 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 60%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>

    <div class="relative container mx-auto px-6 max-w-4xl">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Services / Consulting</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Agentic AI Consulting<br/>
        <span style="background: linear-gradient(135deg, #06b6d4, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          for Orgs That Need to Get It Right
        </span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
        Governance frameworks, ROI assessment, and adoption strategy — built with your team
        using <span class="text-white font-medium">rapid org learning loops</span>, not
        handed over as a deck.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact/?source=consulting"
           class="inline-flex items-center gap-2 px-6 py-3 text-white font-semibold rounded-xl transition-opacity hover:opacity-90 shadow-lg"
           style="background: linear-gradient(135deg, #06b6d4, #0891b2);">
          Book a Free Call →
        </a>
        <a href="#engagements"
           class="inline-flex items-center gap-2 px-6 py-3 text-gray-300 hover:text-white font-medium rounded-xl border border-gray-700/60 hover:border-gray-500/60 transition-colors">
          See engagements
        </a>
      </div>
    </div>
  </section>


  <!-- ─── 3 ENGAGEMENTS ────────────────────────────────────── -->
  <section id="engagements" class="bg-dark-primary py-24">
    <div class="container mx-auto px-6">
      <div class="mb-14">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Engagements</p>
        <h2 class="text-4xl font-bold text-white">Three ways to engage</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {engagements.map(e => (
          <div class="relative p-8 bg-dark-card border border-gray-700/40 rounded-2xl flex flex-col hover:border-gray-600/40 transition-colors duration-300 overflow-hidden">
            <!-- Top colour bar -->
            <div class="absolute top-0 left-0 right-0 h-0.5" style={`background: ${e.color};`}></div>

            <p class="font-mono text-sm font-bold mb-5" style={`color: ${e.color};`}>{e.n}</p>
            <h3 class="text-xl font-bold text-white mb-3 leading-snug">{e.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-6 flex-1">{e.desc}</p>

            <!-- UFL callout -->
            <div class="p-4 rounded-xl mb-6" style={`background: ${e.color}10; border-left: 2px solid ${e.color}50;`}>
              <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5"
                 style={`color: ${e.color};`}>Ultra Fast Learning</p>
              <p class="text-gray-300 text-xs leading-relaxed">{e.ufl}</p>
            </div>

            <!-- Scope -->
            <p class="text-[10px] font-mono uppercase tracking-widest text-gray-400 mb-2">Scope includes</p>
            <p class="text-gray-400 text-xs font-mono mb-6">{e.detail}</p>

            <div class="pt-4 border-t border-gray-700/40 flex items-end justify-between gap-4">
              <div>
                <p class="text-[10px] font-mono uppercase tracking-widest text-gray-400 mb-1">Deliverable</p>
                <p class="text-sm font-semibold" style={`color: ${e.color};`}>{e.deliverable}</p>
              </div>
              <a href={`/contact/?source=${e.source}`}
                 class="inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80 transition-opacity whitespace-nowrap"
                 style={`color: ${e.color};`}>
                Book a Free Call →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── ENGAGEMENT MODELS ────────────────────────────────── -->
  <section class="bg-dark-secondary py-24">
    <div class="container mx-auto px-6">
      <div class="mb-14">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Engagement Models</p>
        <h2 class="text-4xl font-bold text-white">How we work together</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
        <div class="p-8 bg-dark-card border border-gray-700/40 rounded-2xl">
          <div class="w-8 h-0.5 bg-accent mb-6 rounded-full"></div>
          <h3 class="text-xl font-bold text-white mb-3">Project-based</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-5">
            Fixed scope, fixed fee. Clear start, clear end, clear deliverable. Right for
            organisations with a specific problem that needs solving.
          </p>
          <p class="text-xs font-mono text-gray-400">Pricing varies by scope — discovery call required</p>
        </div>
        <div class="p-8 bg-dark-card border border-gray-700/40 rounded-2xl">
          <div class="w-8 h-0.5 bg-accent mb-6 rounded-full"></div>
          <h3 class="text-xl font-bold text-white mb-3">Retainer</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-5">
            Ongoing advisory for organisations that want continuous learning loops, not one-off
            deliverables. Right for orgs in active AI adoption who need a thinking partner.
          </p>
          <p class="text-xs font-mono text-gray-400">Monthly engagement — apply to discuss</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── PROCESS ──────────────────────────────────────────── -->
  <section class="bg-dark-primary py-20">
    <div class="container mx-auto px-6">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-14 text-center">Process</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {processSteps.map(s => (
          <div class="text-center">
            <div class="w-10 h-10 rounded-full border border-accent/30 bg-accent/5 flex items-center justify-center text-accent font-mono text-sm mx-auto mb-4">
              {s.n}
            </div>
            <p class="text-white text-sm font-semibold mb-1">{s.label}</p>
            <p class="text-gray-400 text-xs">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section class="bg-dark-secondary py-24">
    <div class="container mx-auto px-6 text-center max-w-2xl">
      <h2 class="text-3xl font-bold text-white mb-4">Start with a discovery call</h2>
      <p class="text-gray-400 mb-8">No pitch. Just a conversation about where you are and whether there's a fit.</p>
      <a href="/contact/?source=consulting"
         class="inline-flex items-center gap-2 px-8 py-4 text-white font-semibold rounded-xl transition-opacity hover:opacity-90 shadow-lg"
         style="background: linear-gradient(135deg, #06b6d4, #0891b2);">
        Book a Free Call →
      </a>
    </div>
  </section>

</BaseLayout>
