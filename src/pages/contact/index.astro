---
import BaseLayout from '../../layouts/BaseLayout.astro';

const source = Astro.url.searchParams.get('source') ?? '';

// Fine-grained source → human label (shown back to the visitor)
const sourceLabels: Record<string, string> = {
  training:                  'Training programs',
  'training-strategy':       'Agentic AI Project Strategy',
  'training-teams':          'Building Agentic Teams',
  'training-architecture':   'Agentic Architectures Deep Dive',
  'training-implementation': 'Managing Implementation Challenges',
  mentoring:                 'Mentoring & coaching',
  'mentoring-leadership':    'Mentoring — Engineering → AI Leader (Track A)',
  'mentoring-strategy':      'Mentoring — Leader → AI Strategy Owner (Track B)',
  'mentoring-interviews':    'Mentoring — Senior Interview Loops: MAANG & Beyond (Track C)',
  consulting:                'Consulting',
  'consulting-governance':   'Consulting — Governance Framework Design',
  'consulting-roi':          'Consulting — ROI Assessment & Business Case',
  'consulting-adoption':     'Consulting — Agentic AI Adoption Strategy',
};

// Derive coarse intent from fine-grained source (e.g. "mentoring-interviews" → "mentoring")
// so the dropdown pre-selects the right top-level option.
const coarseIntent = source.split('-')[0];
const detectedLabel = sourceLabels[source];

const options = [
  { value: 'training',   label: 'Training programs' },
  { value: 'mentoring',  label: 'Mentoring & coaching' },
  { value: 'consulting', label: 'Consulting engagement' },
  { value: 'other',      label: 'Something else' },
];
---

<BaseLayout
  title="Book a Call"
  description="Start with a 30-minute discovery call — no pitch, just an honest conversation about where you are and whether there's a fit."
>

  <style>
    .field-label {
      display: block;
      font-size: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #6b7280;
      margin-bottom: 0.5rem;
    }
    .field-input {
      width: 100%;
      background: #0d0d14;
      border: 1px solid rgba(75,85,99,0.4);
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      color: white;
      font-size: 0.875rem;
      transition: border-color 0.15s;
      outline: none;
    }
    .field-input:focus {
      border-color: rgba(79,70,229,0.6);
    }
    .field-input::placeholder { color: #4b5563; }
  </style>


  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative py-24 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 65%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative container mx-auto px-6 text-center max-w-2xl">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Contact</p>
      <h1 class="text-5xl font-bold text-white mb-5 leading-tight">Let's start a conversation</h1>
      <p class="text-gray-400 text-lg leading-relaxed">
        30 minutes, no deck, no pitch. Just a direct conversation about where you are and
        whether there's something here worth pursuing.
      </p>
    </div>
  </section>


  <!-- ─── BOOK A CALL (Cal.com inline embed) ───────────────── -->
  <section class="bg-dark-primary py-16 border-b border-gray-800/60">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="text-center mb-10">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-3">Book a Discovery Call</p>
        <h2 class="text-3xl font-bold text-white mb-3">Pick a time that works</h2>
        <p class="text-gray-400 text-sm max-w-lg mx-auto">
          30-minute discovery call on Google Meet. No deck, no pitch — just a direct conversation.
        </p>
      </div>

      <div id="my-cal-inline"
           class="rounded-2xl overflow-hidden border border-gray-800/60 bg-dark-card"
           style="min-height: 640px;"></div>
    </div>
  </section>


  <!-- ─── FORM + SIDEBAR ───────────────────────────────────── -->
  <section class="bg-dark-primary py-20">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-3">Or send a message</p>
        <p class="text-gray-400 text-sm">
          Prefer to share context in writing before booking? Use the form below —
          I read every enquiry personally and respond within 1 business day.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 max-w-5xl mx-auto">

        <!-- Form -->
        <div class="lg:col-span-2">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-6"
          >
            <!-- Netlify hidden fields -->
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="source" value={source} />
            <p class="hidden">
              <label>Don't fill this in: <input name="bot-field" /></label>
            </p>

            {detectedLabel && (
              <div class="p-4 rounded-xl border border-accent/30 bg-accent/5">
                <p class="text-[10px] font-mono uppercase tracking-widest text-accent mb-1">You came from</p>
                <p class="text-white text-sm">{detectedLabel}</p>
              </div>
            )}

            <!-- Name + email row -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="field-label">Your name</label>
                <input id="name" name="name" type="text" required placeholder="Alex Chen" class="field-input" />
              </div>
              <div>
                <label for="email" class="field-label">Work email</label>
                <input id="email" name="email" type="email" required placeholder="alex@company.com" class="field-input" />
              </div>
            </div>

            <!-- Role -->
            <div>
              <label for="role" class="field-label">Your role</label>
              <input id="role" name="role" type="text" placeholder="e.g. CTO, Director of Engineering, Staff Engineer" class="field-input" />
            </div>

            <!-- Interest -->
            <div>
              <label for="interest" class="field-label">I'm interested in</label>
              <select id="interest" name="interest" class="field-input" style="background-color: #0d0d14;">
                {options.map(o => (
                  <option value={o.value} selected={o.value === coarseIntent || undefined}>{o.label}</option>
                ))}
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="field-label">What's the core problem you're trying to solve?</label>
              <textarea
                id="message"
                name="message"
                rows={5}
                placeholder="Give me the honest version — org size, current state, what's stuck."
                class="field-input"
                style="resize: vertical; min-height: 120px;"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 text-white font-semibold rounded-xl transition-all hover:opacity-90 shadow-lg"
              style="background: linear-gradient(135deg, #4f46e5, #6366f1);"
            >
              Send →
            </button>

            <p class="text-gray-600 text-xs text-center">
              I respond to every enquiry personally. Typically within 1 business day.
            </p>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">

          <div class="p-6 bg-dark-card border border-gray-700/40 rounded-2xl">
            <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">What happens next</p>
            <ol class="space-y-4">
              {[
                'I read every enquiry myself and respond within 1 business day.',
                'If there\'s a fit, I\'ll suggest a 30-minute discovery call.',
                'No deck, no pitch. Just an honest conversation.',
                'If there\'s not a fit, I\'ll say so — and point you somewhere useful.',
              ].map((s, i) => (
                <li class="flex gap-3 text-sm text-gray-400">
                  <span class="text-accent font-mono flex-shrink-0">{i + 1}.</span>
                  {s}
                </li>
              ))}
            </ol>
          </div>

          <div class="p-6 bg-dark-card border border-gray-700/40 rounded-2xl">
            <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Good fit if you are</p>
            <ul class="space-y-2.5">
              {[
                'Engineering Manager, Director, CTO, or VP',
                'Staff or Principal Engineer moving into leadership',
                'An org actively building or evaluating AI adoption',
                'Willing to do the work — not just buy the credential',
              ].map(item => (
                <li class="flex items-start gap-2 text-sm text-gray-400">
                  <span class="text-accent flex-shrink-0 mt-0.5">›</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="p-6 bg-dark-card border border-gray-700/40 rounded-2xl">
            <p class="text-xs font-mono uppercase tracking-widest text-accent mb-3">Connect</p>
            <a href="https://linkedin.com" target="_blank" rel="noopener"
               class="flex items-center gap-2.5 text-gray-400 hover:text-white transition-colors text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── Cal.com inline embed loader ──────────────────────── -->
  <script is:inline>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", "discovery-call", { origin: "https://cal.com" });
    Cal.ns["discovery-call"]("inline", {
      elementOrSelector: "#my-cal-inline",
      config: { layout: "month_view" },
      calLink: "thelivingcraft/discovery-call",
    });
    Cal.ns["discovery-call"]("ui", {
      theme: "dark",
      hideEventTypeDetails: false,
      layout: "month_view",
      cssVarsPerTheme: {
        dark: {
          "cal-bg": "#0a0a0f",
          "cal-bg-muted": "#16213e",
          "cal-brand": "#4f46e5",
          "cal-text": "#ffffff",
          "cal-text-muted": "#9ca3af",
          "cal-border": "rgba(75,85,99,0.4)",
        },
      },
    });
  </script>

</BaseLayout>
