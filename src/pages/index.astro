---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Living Craft"
  description="A cohort-based programme that takes senior technical leaders from zero to production-ready agent architecture in four weeks."
>

<style>
  @keyframes badge-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(79,70,229,0); }
    50%       { box-shadow: 0 0 16px 4px rgba(79,70,229,0.35); }
  }
  .badge-glow { animation: badge-glow 3s ease-in-out infinite; }
</style>


<!-- ═══════════════════════════════════════════════════════════
     HERO — The Promise
════════════════════════════════════════════════════════════ -->
<section
  class="relative overflow-hidden py-32 lg:py-40"
  style="background: radial-gradient(ellipse at 60% 20%, #1a1a2e 0%, #0a0a0f 55%);"
>
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: radial-gradient(circle, rgba(79,70,229,0.12) 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse at 60% 30%, black 25%, transparent 70%);"></div>

  <div class="relative container mx-auto px-6 max-w-4xl">
    <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-accent/30 badge-glow mb-8"
         style="background: rgba(79,70,229,0.1);">
      <span class="w-2 h-2 rounded-full bg-accent opacity-80"></span>
      <span class="text-xs font-mono uppercase tracking-widest text-accent">Cohort-based · 4 weeks · Senior leaders only</span>
    </div>

    <h1 class="text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-[1.08] tracking-tight mb-6">
      <span style="background: linear-gradient(135deg, #ffffff 30%, #a0a0c0 100%);
                   -webkit-background-clip: text; -webkit-text-fill-color: transparent;
                   background-clip: text;">
        Learn to architect<br/>production agent systems.<br/>
      </span>
    </h1>

    <p class="text-xl text-gray-400 max-w-2xl leading-relaxed mb-10">
      A four-week cohort for engineering leaders who need to ship autonomous AI — not
      read about it. Small group. Real builds. One outcome: you leave production-ready.
    </p>

    <a href="/apply/"
       class="group inline-flex items-center gap-2.5 px-10 py-5 rounded-xl text-white font-bold text-base transition-all duration-200 shadow-2xl shadow-accent/30 hover:shadow-accent/50"
       style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
      Apply to the cohort
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     WHAT YOU'LL LEAVE WITH
════════════════════════════════════════════════════════════ -->
<section class="py-24 bg-dark-secondary border-y border-gray-800/60">
  <div class="container mx-auto px-6 max-w-4xl">
    <p class="text-xs font-mono uppercase tracking-widest text-accent mb-6">What you'll leave with</p>
    <h2 class="text-3xl font-bold text-white mb-12 leading-snug">
      Four weeks from now, you'll have:
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {[
        {
          title: 'A production-grade agent architecture',
          desc: 'Not a diagram — a working system you designed, built, evaluated, and deployed during the cohort.',
        },
        {
          title: 'The evaluation framework to know if it works',
          desc: 'Custom eval harness for your use case. Metrics that matter. The ability to tell signal from noise in agent output.',
        },
        {
          title: 'Architectural decision records you can defend',
          desc: 'Orchestration patterns, memory strategies, tool-use tradeoffs — documented decisions, not gut feelings.',
        },
        {
          title: 'A peer network operating at your level',
          desc: 'Fifteen senior leaders who just went through the same intensive. The kind of network that compounds.',
        },
      ].map(item => (
        <div class="p-6 rounded-2xl border border-gray-700/40 bg-dark-card">
          <h3 class="text-white font-bold text-lg mb-2">{item.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     PROOF BEAT — Artifact from a cohort
════════════════════════════════════════════════════════════ -->
<section class="py-24 bg-dark-primary">
  <div class="container mx-auto px-6 max-w-3xl">
    <div class="p-8 md:p-10 rounded-2xl border border-accent/20 bg-dark-card relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-0.5"
           style="background: linear-gradient(90deg, #4f46e5, #818cf8, transparent);"></div>

      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">From a recent cohort</p>
      <blockquote class="text-white text-lg font-semibold leading-relaxed mb-4">
        "I came in thinking I understood agents from reading papers. By week three I'd built,
        broken, and rebuilt an orchestration layer that actually handles failure gracefully.
        The difference between reading about it and doing it is everything."
      </blockquote>
      <p class="text-gray-400 text-sm">
        — Senior Engineering Manager, Series B startup
      </p>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     COMPRESSED METHOD — How it works (3 steps)
════════════════════════════════════════════════════════════ -->
<section class="py-24" style="background: #0f0f1a;">
  <div class="container mx-auto px-6 max-w-4xl">
    <p class="text-xs font-mono uppercase tracking-widest text-accent mb-6">The method</p>
    <h2 class="text-3xl font-bold text-white mb-4">
      How four weeks becomes enough
    </h2>
    <p class="text-gray-400 mb-12 max-w-2xl">
      Not a lecture series. Not self-paced videos. A structured programme built on ultralearning
      principles that compress months of self-study into four weeks of building.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {
          step: '01',
          title: 'Build, don\'t study',
          desc: 'Every session produces a working artifact. You learn architecture by architecting — not by reviewing someone else\'s diagrams.',
        },
        {
          step: '02',
          title: 'Tight feedback loops',
          desc: 'Weekly builds reviewed by a practitioner who\'s shipped these systems at scale. Problems surface in days, not months.',
        },
        {
          step: '03',
          title: 'Peer pressure, not willpower',
          desc: 'Fifteen people at your level, shipping on the same cadence. Shared stakes drive pace better than any curriculum.',
        },
      ].map(item => (
        <div class="p-6 rounded-2xl border border-gray-700/30" style="background: rgba(15,15,25,0.8);">
          <p class="text-accent font-mono text-2xl font-bold mb-4 opacity-40">{item.step}</p>
          <h3 class="text-white font-bold text-lg mb-2">{item.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-10">
      <a href="/how-it-works/"
         class="inline-flex items-center gap-2 text-accent hover:text-accent-light text-sm font-semibold transition-colors">
        Read the full method →
      </a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     FINAL CTA
════════════════════════════════════════════════════════════ -->
<section class="relative py-32 overflow-hidden bg-dark-primary">
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[600px] h-[400px] rounded-full"
         style="background: radial-gradient(ellipse, rgba(79,70,229,0.12), transparent 70%); filter: blur(60px);"></div>
  </div>

  <div class="relative container mx-auto px-6 text-center max-w-2xl">
    <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight"
        style="background: linear-gradient(135deg, #ffffff 40%, #9090b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
      The next cohort is forming now.
    </h2>

    <p class="text-gray-400 text-lg mb-10">
      Three questions. No pitch deck, no calendar link — just tell us what you're building
      and we'll tell you if there's a fit.
    </p>

    <a href="/apply/"
       class="group inline-flex items-center gap-2.5 px-10 py-5 rounded-xl text-white font-bold text-base transition-all duration-200 shadow-2xl shadow-accent/30 hover:shadow-accent/50"
       style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
      Apply
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>

</BaseLayout>
