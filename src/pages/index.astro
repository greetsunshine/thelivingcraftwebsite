---
import BaseLayout from '../layouts/BaseLayout.astro';

const metrics = [
  { value: '200+', label: 'Senior Leaders Trained' },
  { value: '40+',  label: 'Organisations Advised'  },
  { value: '90',   label: 'Days to Transformation' },
  { value: '4',    label: 'Expert-Led Programs'    },
];

const pillars = [
  {
    href: '/training/',
    badge: 'Training',
    badgeColor: 'text-violet-400 bg-violet-500/10 border-violet-500/20',
    gradientFrom: 'rgba(139,92,246,0.08)',
    gradientTo: 'rgba(79,70,229,0.04)',
    title: 'Agentic AI Training',
    desc: 'Cohort-based programs that compress years of AI expertise into weeks of structured, application-first learning.',
    outcomes: ['Agentic project strategy', 'Team formation & hiring', 'Architecture patterns'],
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
  },
  {
    href: '/mentoring/',
    badge: 'Mentoring',
    badgeColor: 'text-pink-400 bg-pink-500/10 border-pink-500/20',
    gradientFrom: 'rgba(236,72,153,0.07)',
    gradientTo: 'rgba(139,92,246,0.04)',
    title: 'Mentoring & Coaching',
    desc: '1:1 career transformation — compress two years of leadership growth into a structured 90-day arc with clear milestones.',
    outcomes: ['Career transformation', '90-day structured arc', 'AI leadership track'],
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    href: '/consulting/',
    badge: 'Consulting',
    badgeColor: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
    gradientFrom: 'rgba(6,182,212,0.07)',
    gradientTo: 'rgba(79,70,229,0.04)',
    title: 'Consulting',
    desc: 'Governance frameworks, ROI models, and adoption strategy — built with your team using rapid learning loops, not handed over as a deck.',
    outcomes: ['Governance playbook', 'Board-ready ROI model', '90-day adoption plan'],
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
  {
    href: '/blog/',
    badge: 'Insights',
    badgeColor: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
    gradientFrom: 'rgba(16,185,129,0.07)',
    gradientTo: 'rgba(79,70,229,0.04)',
    title: 'Blog & Projects',
    desc: 'Practitioner-grade thought leadership from real deployments. Every post passes the "usable today" test.',
    outcomes: ['Implementation field notes', 'Architecture deep-dives', 'Leadership frameworks'],
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
];

const posts = [
  {
    tag: 'Architecture', readTime: '8 min',
    title: 'The 5 architecture decisions that determine whether agents work in production',
    excerpt: 'Orchestration patterns, memory strategies, and evaluation loops — the choices made in week one you can\'t easily undo in week eight.',
    date: 'Apr 2026',
  },
  {
    tag: 'Leadership', readTime: '6 min',
    title: 'What engineering managers need to know about agentic AI that nobody tells you',
    excerpt: 'The technical concepts matter less than you think. The org dynamics matter more. A field guide from inside real implementations.',
    date: 'Mar 2026',
  },
];
---

<BaseLayout
  title="The Living Craft"
  description="Practitioner-grade Agentic AI training, mentoring, and consulting for Engineering Managers, Architects, and CTOs. Ultra fast learning."
>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(1deg); }
    50%       { transform: translateY(-14px) rotate(-1deg); }
  }
  @keyframes badge-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(79,70,229,0); }
    50%       { box-shadow: 0 0 16px 4px rgba(79,70,229,0.35); }
  }
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }
  .logo-float   { animation: float 7s ease-in-out infinite; }
  .badge-glow   { animation: badge-glow 3s ease-in-out infinite; }
  .card-hover   { transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease; }
  .card-hover:hover { transform: translateY(-4px); }
  .gradient-border {
    position: relative;
    background: #16213e;
    border-radius: 1rem;
  }
  .gradient-border::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    padding: 1px;
    background: linear-gradient(135deg, rgba(79,70,229,0.4), rgba(99,102,241,0.1), transparent);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
</style>


<!-- ═══════════════════════════════════════════════════════════
     HERO  —  Split layout
════════════════════════════════════════════════════════════ -->
<section
  class="relative min-h-[92vh] flex items-center overflow-hidden"
  style="background: radial-gradient(ellipse at 70% 40%, #1a1a2e 0%, #0a0a0f 55%);"
>
  <!-- Dot grid -->
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: radial-gradient(circle, rgba(79,70,229,0.18) 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse at 60% 50%, black 40%, transparent 80%);"></div>

  <!-- Ambient orbs -->
  <div class="absolute top-1/4 right-1/4 w-[600px] h-[600px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(79,70,229,0.1), transparent 65%); filter: blur(60px);"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(99,102,241,0.06), transparent 70%); filter: blur(80px);"></div>

  <div class="relative container mx-auto px-6 py-24">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: content -->
      <div class="order-2 md:order-1">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-accent/30 badge-glow mb-8"
             style="background: rgba(79,70,229,0.1);">
          <span class="w-2 h-2 rounded-full bg-accent opacity-80"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-accent">
            AI · Training · Consulting · Projects
          </span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl lg:text-6xl xl:text-7xl font-extrabold leading-[1.05] tracking-tight mb-6">
          <span style="background: linear-gradient(135deg, #ffffff 30%, #a0a0c0 100%);
                       -webkit-background-clip: text; -webkit-text-fill-color: transparent;
                       background-clip: text;">
            Lead the<br/>Agentic<br/>AI Shift
          </span>
        </h1>

        <!-- Subhead -->
        <p class="text-lg text-gray-400 max-w-lg mb-10 leading-relaxed">
          Practitioner-grade training, mentoring, and consulting for Engineering Managers,
          Architects, and CTOs. Built for
          <span class="text-white font-semibold">ultra fast learning</span> —
          every engagement produces results you use the next morning.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-12">
          <a href="/training/"
             class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-white font-semibold text-sm transition-all duration-200 shadow-lg shadow-accent/30 hover:shadow-accent/50"
             style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
            Explore Programs
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/contact/"
             class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-gray-300 hover:text-white font-semibold text-sm border border-gray-600/70 hover:border-gray-400 transition-all duration-200"
             style="background: rgba(255,255,255,0.03);">
            Book a Discovery Call
          </a>
        </div>

        <!-- Role strip -->
        <div class="flex flex-wrap gap-2">
          {['Engineering Manager','Staff Engineer','Principal Architect','CTO','VP Engineering','AI Team Lead'].map(r => (
            <span class="px-3 py-1 rounded-full text-xs font-mono text-gray-500 border border-gray-700/60"
                  style="background: rgba(255,255,255,0.02);">
              {r}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: logo card -->
      <div class="order-1 md:order-2 flex justify-center md:justify-end">
        <div class="relative logo-float">
          <!-- Glow rings -->
          <div class="absolute -inset-6 rounded-3xl pointer-events-none"
               style="background: radial-gradient(circle, rgba(79,70,229,0.2), transparent 70%); filter: blur(24px);"></div>
          <div class="absolute -inset-2 rounded-2xl pointer-events-none opacity-60"
               style="background: radial-gradient(circle, rgba(99,102,241,0.15), transparent 70%); filter: blur(12px);"></div>
          <!-- Card -->
          <div class="relative w-56 sm:w-64 lg:w-72 rounded-2xl overflow-hidden shadow-2xl shadow-black/60"
               style="background: #f0ebe0; border: 1px solid rgba(255,255,255,0.08);">
            <img src="/logo.svg" alt="The Living Craft" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
       style="background: linear-gradient(to bottom, transparent, #0a0a0f);"></div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     METRICS STRIP
════════════════════════════════════════════════════════════ -->
<section class="border-y border-gray-800/60" style="background: #111120;">
  <div class="container mx-auto px-6 py-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
      {metrics.map(m => (
        <div class="text-center">
          <p class="text-3xl lg:text-4xl font-extrabold font-mono mb-1"
             style="background: linear-gradient(135deg, #fff 40%, #a0a0c0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            {m.value}
          </p>
          <p class="text-gray-500 text-xs uppercase tracking-widest font-mono">{m.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     THE GAP
════════════════════════════════════════════════════════════ -->
<section class="py-28" style="background: #0f0f1a;">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mb-16">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-5">The Challenge</p>
      <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-6"
          style="background: linear-gradient(135deg, #fff 50%, #808098); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
        Your team is experimenting.<br/>Your org needs results.
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed">
        Every week spent in proof-of-concept mode is a week your competitors are shipping.
        The gap isn't technology — it's strategy, team design, and governance.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {[
        {
          n: '01',
          headline: 'Projects stall at proof-of-concept',
          body: 'Demos work. Production doesn\'t. The gap is strategic framing and team design, not model capability.',
          color: 'rgba(139,92,246,0.12)',
          border: 'rgba(139,92,246,0.25)',
        },
        {
          n: '02',
          headline: 'You can\'t form a team that knows what they\'re doing',
          body: 'The talent market hasn\'t caught up. You need to build Agentic AI expertise from within — fast.',
          color: 'rgba(79,70,229,0.12)',
          border: 'rgba(79,70,229,0.25)',
        },
        {
          n: '03',
          headline: 'The board wants ROI — you need a framework',
          body: 'Experimentation budgets are closing. Governance models and defensible ROI are now table stakes.',
          color: 'rgba(99,102,241,0.12)',
          border: 'rgba(99,102,241,0.25)',
        },
      ].map(c => (
        <div class="card-hover relative p-8 rounded-2xl border overflow-hidden"
             style={`background: ${c.color}; border-color: ${c.border};`}>
          <!-- Number watermark -->
          <div class="absolute top-5 right-6 font-mono font-black text-6xl leading-none select-none pointer-events-none"
               style="color: rgba(255,255,255,0.04);">{c.n}</div>
          <p class="text-xs font-mono text-accent mb-5 uppercase tracking-widest">{c.n}</p>
          <h3 class="text-white font-bold text-lg mb-3 leading-snug">{c.headline}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     4 PILLARS
════════════════════════════════════════════════════════════ -->
<section class="py-28 bg-dark-primary">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-16">
      <div>
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-5">How We Help</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Four paths to<br/>AI leadership
        </h2>
      </div>
      <p class="text-gray-500 text-sm leading-relaxed max-w-xs">
        Every engagement is anchored in ultra fast learning.<br/>
        No theory without same-week application.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {pillars.map(p => (
        <a href={p.href}
           class="card-hover gradient-border group block p-8 rounded-2xl"
           style={`background: linear-gradient(135deg, ${p.gradientFrom}, ${p.gradientTo}, #16213e);`}>

          <div class="flex items-start justify-between mb-6">
            <!-- Icon + badge row -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-gray-700/60 group-hover:border-accent/30 transition-colors"
                   style="background: rgba(255,255,255,0.04);">
                <span class="text-accent">
                  <Fragment set:html={p.icon} />
                </span>
              </div>
              <span class={`px-2.5 py-1 rounded-full text-xs font-mono font-semibold border ${p.badgeColor}`}>
                {p.badge}
              </span>
            </div>
            <span class="text-gray-600 group-hover:text-accent group-hover:translate-x-1 transition-all duration-200 text-xl leading-none mt-1">→</span>
          </div>

          <h3 class="text-xl font-bold text-white mb-3 leading-snug group-hover:text-accent-light transition-colors duration-200">
            {p.title}
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">{p.desc}</p>

          <!-- Outcome bullets -->
          <ul class="space-y-1.5 border-t border-gray-700/50 pt-5">
            {p.outcomes.map(o => (
              <li class="flex items-center gap-2 text-xs text-gray-500 font-mono">
                <span class="text-accent opacity-60">›</span>
                {o}
              </li>
            ))}
          </ul>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     ULTRA FAST LEARNING — Animated Engine
════════════════════════════════════════════════════════════ -->
<section class="relative py-28 overflow-hidden" style="background: #0c0c18;">

  <style>
    /* ── Gear spins ──────────────────────────────────────── */
    @keyframes ufl-gear-cw  { to { transform: rotate(360deg);  } }
    @keyframes ufl-gear-ccw { to { transform: rotate(-360deg); } }
    .ufl-gear-large { animation: ufl-gear-cw  8s linear infinite; transform-box: fill-box; transform-origin: center; }
    .ufl-gear-small { animation: ufl-gear-ccw 5.3s linear infinite; transform-box: fill-box; transform-origin: center; }

    /* ── Neural-node pulse (staggered) ──────────────────── */
    @keyframes ufl-node { 0%,100%{opacity:.2} 50%{opacity:1} }
    .un0{animation:ufl-node 2.4s ease-in-out infinite 0.0s}
    .un1{animation:ufl-node 2.4s ease-in-out infinite 0.4s}
    .un2{animation:ufl-node 2.4s ease-in-out infinite 0.8s}
    .un3{animation:ufl-node 2.4s ease-in-out infinite 1.2s}
    .un4{animation:ufl-node 2.4s ease-in-out infinite 1.6s}
    .un5{animation:ufl-node 2.4s ease-in-out infinite 2.0s}

    /* ── Signal pulse along edges ───────────────────────── */
    @keyframes ufl-sig {
      0%   { stroke-dashoffset: 60; opacity: 0;   }
      15%  { opacity: 1; }
      85%  { opacity: 1; }
      100% { stroke-dashoffset: 0;  opacity: 0;   }
    }
    .us { stroke-dasharray: 5 60; }
    .us0{animation:ufl-sig 2.4s linear infinite 0.0s}
    .us1{animation:ufl-sig 2.4s linear infinite 0.4s}
    .us2{animation:ufl-sig 2.4s linear infinite 0.8s}
    .us3{animation:ufl-sig 2.4s linear infinite 1.2s}
    .us4{animation:ufl-sig 2.4s linear infinite 1.6s}
    .us5{animation:ufl-sig 2.4s linear infinite 2.0s}

    /* ── Progress bars ───────────────────────────────────── */
    @keyframes ufl-bar-slow {
      0%  { width:0%;   }
      90% { width:55%;  }
      100%{ width:55%;  }
    }
    @keyframes ufl-bar-fast {
      0%  { width:0%;   }
      28% { width:100%; }
      100%{ width:100%; }
    }
    .ufl-bar-slow { animation: ufl-bar-slow 9s cubic-bezier(.5,0,.9,1) infinite; }
    .ufl-bar-fast { animation: ufl-bar-fast 2.6s cubic-bezier(.05,0,.15,1) infinite; }

    /* ── Concept tape ────────────────────────────────────── */
    @keyframes ufl-tape { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .ufl-tape { animation: ufl-tape 18s linear infinite; display:flex; white-space:nowrap; }

    /* ── Artifact pop-in (staggered loop) ───────────────── */
    @keyframes ufl-pop {
      0%,100%{ opacity:0; transform:translateY(6px); }
      10%,85%{ opacity:1; transform:translateY(0);   }
    }
    .ap0{animation:ufl-pop 8s ease-in-out infinite 0.0s}
    .ap1{animation:ufl-pop 8s ease-in-out infinite 1.6s}
    .ap2{animation:ufl-pop 8s ease-in-out infinite 3.2s}
    .ap3{animation:ufl-pop 8s ease-in-out infinite 4.8s}
    .ap4{animation:ufl-pop 8s ease-in-out infinite 6.4s}
  </style>

  <!-- Dot-grid background -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
       style="background-image:radial-gradient(circle,#4f46e5 1px,transparent 1px);background-size:28px 28px;"></div>

  <div class="container mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">The Method</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
        Ultra Fast Learning
      </h2>
      <p class="text-gray-400 text-lg max-w-xl mx-auto leading-relaxed">
        Not shortcuts. Ruthless sequencing — the right concepts, applied before the session ends.
      </p>
    </div>

    <!-- ── Main engine visual ──────────────────────────── -->
    <div class="max-w-5xl mx-auto">

      <!-- Three-column: neural net | compression | gear -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6 items-center">

        <!-- ── Neural network (logo element, animated) ── -->
        <div class="flex flex-col items-center gap-4">
          <p class="text-xs font-mono text-gray-600 uppercase tracking-widest">Knowledge Graph</p>
          <svg viewBox="0 0 140 140" class="w-36 h-36">
            <!-- Edges (static, dim) -->
            <g stroke="#4f46e5" stroke-width="0.8" opacity="0.25" fill="none">
              <line x1="70" y1="62" x2="70" y2="28"/>
              <line x1="70" y1="62" x2="99" y2="45"/>
              <line x1="70" y1="62" x2="99" y2="78"/>
              <line x1="70" y1="78" x2="70" y2="112"/>
              <line x1="70" y1="78" x2="41" y2="95"/>
              <line x1="70" y1="62" x2="41" y2="45"/>
            </g>
            <!-- Signal pulses -->
            <line class="us us0" x1="70" y1="62" x2="70"  y2="28"  stroke="#818cf8" stroke-width="2"/>
            <line class="us us1" x1="70" y1="62" x2="99"  y2="45"  stroke="#818cf8" stroke-width="2"/>
            <line class="us us2" x1="70" y1="62" x2="99"  y2="78"  stroke="#818cf8" stroke-width="2"/>
            <line class="us us3" x1="70" y1="78" x2="70"  y2="112" stroke="#818cf8" stroke-width="2"/>
            <line class="us us4" x1="70" y1="78" x2="41"  y2="95"  stroke="#818cf8" stroke-width="2"/>
            <line class="us us5" x1="70" y1="62" x2="41"  y2="45"  stroke="#818cf8" stroke-width="2"/>
            <!-- Orbital nodes -->
            <circle class="un1" cx="70"  cy="28"  r="7" fill="#6366f1"/>
            <circle class="un2" cx="99"  cy="45"  r="7" fill="#818cf8"/>
            <circle class="un3" cx="99"  cy="78"  r="7" fill="#6366f1"/>
            <circle class="un4" cx="70"  cy="112" r="7" fill="#818cf8"/>
            <circle class="un5" cx="41"  cy="95"  r="7" fill="#6366f1"/>
