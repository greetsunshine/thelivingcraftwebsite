---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Living Craft"
  description="Practitioner-grade Agentic AI training, mentoring, and consulting — anchored in ultra fast learning. For Engineering Managers, Architects, and CTOs."
>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(1deg); }
    50%       { transform: translateY(-14px) rotate(-1deg); }
  }
  @keyframes badge-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(79,70,229,0); }
    50%       { box-shadow: 0 0 16px 4px rgba(79,70,229,0.35); }
  }
  @media (prefers-reduced-motion: reduce) {
    .logo-float { animation: none !important; }
  }
  .logo-float   { animation: float 4s ease-in-out infinite; }
  .badge-glow   { animation: badge-glow 3s ease-in-out infinite; }
  .card-hover   { transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease; }
  .card-hover:hover { transform: translateY(-4px); }
</style>


<!-- ═══════════════════════════════════════════════════════════
     HERO — Headline → Skills → CTAs (one block)
════════════════════════════════════════════════════════════ -->
<section
  class="relative overflow-hidden"
  style="background: radial-gradient(ellipse at 60% 20%, #1a1a2e 0%, #0a0a0f 55%);"
>
  <!-- Dot grid -->
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: radial-gradient(circle, rgba(79,70,229,0.15) 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse at 60% 30%, black 25%, transparent 70%);"></div>
  <div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(79,70,229,0.08), transparent 65%); filter: blur(60px);"></div>

  <div class="relative container mx-auto px-6">

    <!-- ── ROW 1: Headline + Edge Card ─────────────────── -->
    <div class="pt-24 pb-14">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-10 xl:gap-16 items-start">

        <!-- Left: the hook -->
        <div>
          <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-accent/30 badge-glow mb-8"
               style="background: rgba(79,70,229,0.1);">
            <span class="w-2 h-2 rounded-full bg-accent opacity-80"></span>
            <span class="text-xs font-mono uppercase tracking-widest text-accent">2026 — The Agentic AI era</span>
          </div>

          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-[1.08] tracking-tight mb-6">
            <span style="background: linear-gradient(135deg, #ffffff 30%, #a0a0c0 100%);
                         -webkit-background-clip: text; -webkit-text-fill-color: transparent;
                         background-clip: text;">
              The Agentic AI skills<br/>gap is real.<br/>
            </span>
            <span class="text-accent">We close it — fast.</span>
          </h1>

          <p class="text-lg text-gray-400 max-w-xl leading-relaxed">
            The leaders who learn to architect, build, and deploy autonomous AI systems
            <em>this year</em> will have a compounding career advantage for the next decade.
            We get you there in weeks — not the years most people spend fumbling through
            self-study and generic courses.
          </p>
        </div>

        <!-- Right: The Living Craft edge card -->
        <div class="hidden lg:block">
          <div class="rounded-2xl border border-gray-700/30 overflow-hidden"
               style="background: linear-gradient(160deg, rgba(79,70,229,0.08), rgba(10,10,20,0.95));">

            <!-- Brand header -->
            <div class="p-5 flex items-center gap-3 border-b border-gray-700/30">
              <div class="w-10 h-auto rounded-lg overflow-hidden border border-gray-700/50"
                   style="background: #f0ebe0;">
                <img src="/TheLivingCraftlogo.png" alt="The Living Craft" class="w-full h-auto object-contain" />
              </div>
              <div>
                <p class="text-white font-bold text-sm">The Living <span class="text-accent">Craft</span></p>
                <p class="text-gray-400 text-[10px] font-mono">Why we're different</p>
              </div>
            </div>

            <!-- Pedigree — the headline credential -->
            <div class="px-5 pt-5 pb-4">
              <p class="text-[10px] font-mono uppercase tracking-widest text-accent mb-3">Pedigree</p>
              <p class="text-white font-bold text-lg leading-snug mb-1">
                26+ years at <span class="text-accent">Amazon</span> &amp; <span class="text-accent">Google</span>
              </p>
              <p class="text-gray-400 text-xs leading-relaxed">
                Fortune 10 engineering leadership. Built and shipped production AI systems at global scale.
              </p>
            </div>

            <!-- Edge items -->
            <div class="px-5 pb-5 space-y-4">
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-white font-semibold text-xs">Billions-Scale Distributed Systems</p>
                  <p class="text-gray-400 text-xs leading-relaxed">
                    Multi-geography, high-scale architectures serving billions of users. Not prototypes — production systems under real load.
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                <div>
                  <p class="text-white font-semibold text-xs">Hired &amp; Grew L6+ Talent</p>
                  <p class="text-gray-400 text-xs leading-relaxed">
                    Hired and grew senior talent at Amazon and Google. Developed and promoted senior engineers into staff and leadership roles.
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <div>
                  <p class="text-white font-semibold text-xs">Production-Ready in Weeks</p>
                  <p class="text-gray-400 text-xs leading-relaxed">
                    Structured fast learning. You ship usable artifacts from session one — not after a 6-month course.
                  </p>
                </div>
              </div>
            </div>

            <!-- Stats footer -->
            <div class="px-5 py-4 border-t border-gray-700/30 flex items-center justify-between"
                 style="background: rgba(79,70,229,0.05);">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold font-mono text-white">200+</span>
                <span class="text-gray-400 text-xs font-mono">leaders trained</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold font-mono text-white">40+</span>
                <span class="text-gray-400 text-xs font-mono">orgs advised</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>


    <!-- ── ROW 2: Skills — flows naturally from headline ── -->
    <div class="pb-10 pt-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
        <div>
          <p class="text-xs font-mono uppercase tracking-widest text-accent mb-2">The skills that will define careers</p>
          <h2 class="text-2xl font-bold text-white">Four capabilities the market is desperate for</h2>
        </div>
        <p class="text-gray-400 text-sm max-w-xs">
          The supply of people who have these? <span class="text-white font-semibold">Almost zero.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { skill: 'Agent Architecture', one: 'Orchestration, memory, tool use, evaluation loops — the decisions that make or break production.', color: '#4f46e5' },
          { skill: 'AI-Native Teams', one: 'New roles, topologies, and hiring rubrics for teams where AI agents are first-class members.', color: '#818cf8' },
          { skill: 'Governance & Risk', one: 'Policies and frameworks that let you deploy fast enough to compete and safe enough to sleep.', color: '#6366f1' },
          { skill: 'Strategic AI Leadership', one: 'Own the AI strategy at board level. Translate engineering reality into funded roadmaps.', color: '#a78bfa' },
        ].map(s => (
          <div class="p-5 rounded-xl border border-gray-700/30" style="background: rgba(15,15,25,0.7);">
            <div class="w-6 h-0.5 rounded-full mb-4" style={`background: ${s.color};`}></div>
            <h3 class="text-white font-bold text-sm mb-1.5">{s.skill}</h3>
            <p class="text-gray-400 text-xs leading-relaxed">{s.one}</p>
          </div>
        ))}
      </div>
    </div>


    <!-- ── ROW 3: CTAs + role strip — after skills ──────── -->
    <div class="pb-20 pt-8">
      <div class="flex flex-wrap gap-4 mb-8">
        <a href="#offerings"
           class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-white font-semibold text-sm transition-all duration-200 shadow-lg shadow-accent/30 hover:shadow-accent/50"
           style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
          See What We Offer
          <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
        <a href="/contact/"
           class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-gray-300 hover:text-white font-semibold text-sm border border-gray-600/70 hover:border-gray-400 transition-all duration-200"
           style="background: rgba(255,255,255,0.03);">
          Book a Free Call
        </a>
      </div>

      <div class="flex flex-wrap gap-2">
        {['Engineering Manager','Staff Engineer','Principal Architect','CTO','VP Engineering','AI Team Lead'].map(r => (
          <span class="px-3 py-1 rounded-full text-xs font-mono text-gray-400 border border-gray-700/60"
                style="background: rgba(255,255,255,0.02);">
            {r}
          </span>
        ))}
      </div>
    </div>

  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
       style="background: linear-gradient(to bottom, transparent, #0f0f1a);"></div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     OFFERINGS — Training · Mentoring · Consulting
     Each anchored to Ultra Fast Learning
════════════════════════════════════════════════════════════ -->
<section id="offerings" class="py-28" style="background: #0f0f1a;">
  <div class="container mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">What We Offer</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
        Everything we do<br/>is built to accelerate you
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
        Train your team. Transform your career. Build your org's AI strategy. Ship real projects.
        Four offerings, one principle — every engagement compresses months into weeks.
      </p>
    </div>


    <!-- ── TRAINING ─────────────────────────────────────── -->
    <div class="mb-6">
      <a href="/training/"
         class="card-hover group block rounded-2xl border border-gray-700/40 hover:border-violet-500/30 overflow-hidden transition-all duration-300"
         style="background: linear-gradient(135deg, rgba(139,92,246,0.06), rgba(79,70,229,0.03), #16213e);">
        <div class="h-1 w-full" style="background: linear-gradient(90deg, #8b5cf6, #6366f1, transparent);"></div>
        <div class="p-8 md:p-10">
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">

            <!-- Left: content -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-violet-500/30"
                     style="background: rgba(139,92,246,0.1);">
                  <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                </div>
                <span class="px-2.5 py-1 rounded-full text-xs font-mono font-semibold text-violet-400 bg-violet-500/10 border border-violet-500/20">
                  Training
                </span>
              </div>

              <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-violet-300 transition-colors">
                Agentic AI Training Programs
              </h3>
              <p class="text-gray-400 leading-relaxed mb-6 max-w-2xl">
                Four programs designed for different learning styles and career stages.
                Go deep in a 3-week intensive. Learn on weekends while keeping your day job.
                Prep for MAANG interviews. Or learn to build an AI-first organisation from the ground up.
              </p>

              <!-- Speed lever -->
              <div class="flex items-start gap-3 p-4 rounded-xl mb-6"
                   style="background: rgba(139,92,246,0.08); border-left: 2px solid rgba(139,92,246,0.4);">
                <span class="text-violet-400 flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </span>
                <div>
                  <p class="text-xs font-mono font-semibold text-violet-400 mb-1">Why it's fast</p>
                  <p class="text-gray-300 text-sm leading-relaxed">
                    Small cohorts (fewer than 15). Hybrid format (online + in-person). Every session produces a usable artifact — not slides.
                  </p>
                </div>
              </div>

              <span class="inline-flex items-center gap-2 text-sm font-semibold text-violet-400 group-hover:translate-x-1 transition-transform">
                View all 4 programs →
              </span>
            </div>

            <!-- Right: program list -->
            <div class="space-y-3">
              <p class="text-[10px] font-mono uppercase tracking-widest text-gray-400 mb-1">Programs</p>
              {[
                { title: 'Fast-Track Intensive', sub: '3–4 weeks · Mon–Fri · 2 tracks', color: '#8b5cf6' },
                { title: 'Weekend Leadership', sub: '6–8 weekends + mid-week AMA', color: '#a78bfa' },
                { title: 'MAANG Interview Mastery', sub: '4–6 weeks · 1:1 + mock loops', color: '#c4b5fd' },
                { title: 'Agentic Organisations', sub: '6–8 weeks · C-suite cohort', color: '#ddd6fe' },
              ].map(prog => (
                <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700/30 hover:border-violet-500/20 transition-colors"
                     style="background: rgba(10,10,20,0.5);">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${prog.color};`}></span>
                  <div>
                    <p class="text-white text-sm font-semibold">{prog.title}</p>
                    <p class="text-gray-400 text-xs font-mono">{prog.sub}</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        </div>
      </a>
    </div>


    <!-- ── MENTORING + CONSULTING — side by side ─────── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

      <!-- Mentoring -->
      <a href="/mentoring/"
         class="card-hover group flex flex-col rounded-2xl border border-gray-700/40 hover:border-pink-500/30 overflow-hidden transition-all duration-300"
         style="background: linear-gradient(135deg, rgba(236,72,153,0.05), rgba(139,92,246,0.03), #16213e);">
        <div class="h-1 w-full" style="background: linear-gradient(90deg, #ec4899, #f472b6, transparent);"></div>
        <div class="p-8 flex flex-col flex-1">

          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-pink-500/30"
                 style="background: rgba(236,72,153,0.1);">
              <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="px-2.5 py-1 rounded-full text-xs font-mono font-semibold text-pink-400 bg-pink-500/10 border border-pink-500/20">
              Mentoring
            </span>
          </div>

          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-pink-300 transition-colors">
            1:1 Career Transformation
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6 flex-1">
            Personalised mentoring across three tracks — engineering to AI leadership,
            leader to AI strategy owner, and senior interview loops for MAANG & beyond.
            90-day arcs with measurable milestones, not vague coaching conversations.
          </p>

          <!-- Speed lever -->
          <div class="flex items-start gap-3 p-4 rounded-xl mb-6"
               style="background: rgba(236,72,153,0.06); border-left: 2px solid rgba(236,72,153,0.35);">
            <span class="text-pink-400 flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </span>
            <div>
              <p class="text-xs font-mono font-semibold text-pink-400 mb-1">Why it's fast</p>
              <p class="text-gray-300 text-xs leading-relaxed">
                Action contract every session. Day-45 checkpoint. What most leaders figure out in 2 years — compressed into a 90-day arc.
              </p>
            </div>
          </div>

          <!-- Track list -->
          <div class="space-y-2 mb-6">
            {[
              { label: 'Engineering → AI Leader', sub: 'Bi-weekly · 90 days' },
              { label: 'Leader → AI Strategy Owner', sub: 'Monthly + async' },
              { label: 'MAANG Senior Interview Loops', sub: '4–6 week intensive' },
            ].map(t => (
              <div class="flex items-center gap-2 text-xs font-mono text-gray-400">
                <span class="text-pink-400 opacity-60">›</span>
                <span class="text-gray-300">{t.label}</span>
                <span class="text-gray-400 ml-auto">{t.sub}</span>
              </div>
            ))}
          </div>

          <span class="inline-flex items-center gap-2 text-sm font-semibold text-pink-400 group-hover:translate-x-1 transition-transform mt-auto">
            Learn more →
          </span>
        </div>
      </a>

      <!-- Consulting -->
      <a href="/consulting/"
         class="card-hover group flex flex-col rounded-2xl border border-gray-700/40 hover:border-cyan-500/30 overflow-hidden transition-all duration-300"
         style="background: linear-gradient(135deg, rgba(6,182,212,0.05), rgba(79,70,229,0.03), #16213e);">
        <div class="h-1 w-full" style="background: linear-gradient(90deg, #06b6d4, #22d3ee, transparent);"></div>
        <div class="p-8 flex flex-col flex-1">

          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-cyan-500/30"
                 style="background: rgba(6,182,212,0.1);">
              <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <span class="px-2.5 py-1 rounded-full text-xs font-mono font-semibold text-cyan-400 bg-cyan-500/10 border border-cyan-500/20">
              Consulting
            </span>
          </div>

          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-cyan-300 transition-colors">
            Org-Level AI Strategy
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6 flex-1">
            Governance frameworks, ROI models, and adoption strategy — built with your team,
            not handed over as a deck. Your team learns while the work gets done.
            Project-based or retainer, depending on what you need.
          </p>

          <!-- Speed lever -->
          <div class="flex items-start gap-3 p-4 rounded-xl mb-6"
               style="background: rgba(6,182,212,0.06); border-left: 2px solid rgba(6,182,212,0.35);">
            <span class="text-cyan-400 flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </span>
            <div>
              <p class="text-xs font-mono font-semibold text-cyan-400 mb-1">Why it's fast</p>
              <p class="text-gray-300 text-xs leading-relaxed">
                Working draft by end of week 2. Day-30 checkpoint. Your team builds competence during the engagement — not after it.
              </p>
            </div>
          </div>

          <!-- Engagement list -->
          <div class="space-y-2 mb-6">
            {[
              { label: 'Governance Framework Design', sub: 'Playbook deliverable' },
              { label: 'ROI Assessment & Business Case', sub: 'Board-ready model' },
              { label: 'Agentic AI Adoption Strategy', sub: '90-day roadmap' },
            ].map(e => (
              <div class="flex items-center gap-2 text-xs font-mono text-gray-400">
                <span class="text-cyan-400 opacity-60">›</span>
                <span class="text-gray-300">{e.label}</span>
                <span class="text-gray-400 ml-auto hidden sm:inline">{e.sub}</span>
              </div>
            ))}
          </div>

          <span class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 group-hover:translate-x-1 transition-transform mt-auto">
            Learn more →
          </span>
        </div>
      </a>

    </div>


    <!-- ── PROJECTS — Build Together ─────────────────── -->
    <a href="/projects/"
       class="card-hover group block rounded-2xl border border-gray-700/40 hover:border-emerald-500/30 overflow-hidden transition-all duration-300"
       style="background: linear-gradient(135deg, rgba(16,185,129,0.05), rgba(79,70,229,0.03), #16213e);">
      <div class="h-1 w-full" style="background: linear-gradient(90deg, #10b981, #34d399, transparent);"></div>
      <div class="p-8 md:p-10">
