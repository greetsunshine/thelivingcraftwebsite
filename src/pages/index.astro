---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgramPage from '../components/ProgramPage.astro';
import { regions } from '../data/regions';

// One page; only the pricing block changes by region. No redirect, no duplicate content.
export const prerender = false;

const VALID = ['india', 'dubai', 'australia'] as const;
type Key = (typeof VALID)[number];

// 1) explicit ?region= wins (shareable links)  2) else geo  3) else neutral pricing
const param = Astro.url.searchParams.get('region')?.toLowerCase();
const geoMap: Record<string, Key> = { IN: 'india', AE: 'dubai', AU: 'australia' };
const geo = Astro.request.headers.get('x-vercel-ip-country')?.toUpperCase() ?? '';

const key: Key | undefined = VALID.includes(param as Key) ? (param as Key) : geoMap[geo];
const region = key ? regions[key] : null;

// Region varies per visitor/param — don't let a shared cache serve the wrong price.
Astro.response.headers.set('Cache-Control', 'no-store');

const title = 'The Living Craft — Agentic & Systems Architecture by Sunil Mathew';
const description =
  'An application-only, 5-week program in agentic & systems architecture, taught from 26 years building and leading engineering at Google, Amazon, and Walmart.';
---

<BaseLayout title={title} description={description} canonical="https://learning.thelivingcraft.ai/">
  <ProgramPage region={region} />
</BaseLayout>
