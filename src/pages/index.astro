---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Living Craft" description="Master the Art of Systems & AI - Advanced engineering courses designed for engineering managers, architects, and senior engineers building tomorrow's technologies.">
	<!-- Hero Section -->
	<section class="container mx-auto px-6 py-16 text-center">
		<!-- Badge -->
		<div class="inline-flex items-center px-4 py-2 bg-dark-card rounded-full text-sm text-accent-light mb-8 border border-accent/20">
			ADVANCED ENGINEERING COURSES
		</div>
		
		<!-- Main Heading -->
		<h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
			Master the Art of <span class="text-accent">Systems</span> & <span class="text-accent">AI</span>
		</h1>
		
		<!-- Subtitle -->
		<p class="text-xl text-gray-300 mb-16 max-w-4xl mx-auto leading-relaxed">
			Industry-leading courses designed for engineering managers, architects, and senior engineers building tomorrow's technologies.
		</p>
	</section>

	<!-- Courses Section -->
	<section class="container mx-auto px-6 py-16">
		<div class="mb-12">
			<p class="text-sm text-gray-400 uppercase tracking-wider mb-4">AVAILABLE COURSES</p>
			<h2 class="text-4xl font-bold">Choose Your Learning Path</h2>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
			<!-- Agentic Architecture Course -->
			<div class="bg-dark-card border border-gray-700 rounded-2xl p-8 hover:border-accent/30 transition-all duration-300">
				<div class="mb-6">
					<span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full mb-4">
						ADVANCED
					</span>
					<h3 class="text-2xl font-bold mb-3">Agentic Architecture</h3>
					<p class="text-accent-light font-medium mb-4">Master AI Agent Workflows</p>
					<p class="text-gray-300 leading-relaxed">
						Learn advanced agentic architecture patterns from industry experts. For engineering managers and architects building autonomous AI systems.
					</p>
				</div>

				<div class="flex items-center justify-between mb-6">
					<div class="flex space-x-8">
						<div>
							<p class="text-accent text-xl font-bold">8 weeks</p>
							<p class="text-gray-400 text-sm">Duration</p>
						</div>
						<div>
							<p class="text-accent text-xl font-bold">$3500</p>
							<p class="text-gray-400 text-sm">Investment</p>
						</div>
						<div>
							<p class="text-accent text-xl font-bold">50</p>
							<p class="text-gray-400 text-sm">Cohort Size</p>
						</div>
					</div>
				</div>

				<button class="flex items-center text-accent hover:text-accent-light transition-colors group">
					<span class="mr-2">Explore Course</span>
					<svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
					</svg>
				</button>
			</div>

			<!-- Systems Design Mastery Course -->
			<div class="bg-dark-card border border-gray-700 rounded-2xl p-8 hover:border-accent/30 transition-all duration-300">
				<div class="mb-6">
					<span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full mb-4">
						ADVANCED
					</span>
					<h3 class="text-2xl font-bold mb-3">Systems Design Mastery</h3>
					<p class="text-accent-light font-medium mb-4">Build Scalable Systems</p>
					<p class="text-gray-300 leading-relaxed">
						Master the art of designing systems that scale to millions of users. For senior engineers and tech leads.
					</p>
				</div>

				<div class="flex items-center justify-between mb-6">
					<div class="flex space-x-8">
						<div>
							<p class="text-accent text-xl font-bold">10 weeks</p>
							<p class="text-gray-400 text-sm">Duration</p>
						</div>
						<div>
							<p class="text-accent text-xl font-bold">$2999</p>
							<p class="text-gray-400 text-sm">Investment</p>
						</div>
						<div>
							<p class="text-accent text-xl font-bold">40</p>
							<p class="text-gray-400 text-sm">Cohort Size</p>
						</div>
					</div>
				</div>

				<button class="flex items-center text-accent hover:text-accent-light transition-colors group">
					<span class="mr-2">Explore Course</span>
					<svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
					</svg>
				</button>
			</div>
		</div>
	</section>
</BaseLayout>
