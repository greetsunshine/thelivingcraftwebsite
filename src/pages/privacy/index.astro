---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for The Living Craft — how we handle your data."
>

  <section
    class="relative py-28 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 60%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>

    <div class="relative container mx-auto px-6 max-w-3xl">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Legal</p>
      <h1 class="text-5xl font-bold text-white mb-6 leading-tight">Privacy Policy</h1>
      <p class="text-gray-400 text-sm font-mono mb-2">Last updated: April 2026</p>
    </div>
  </section>

  <section class="bg-dark-primary py-20">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="prose prose-invert prose-sm max-w-none space-y-8">

        <div>
          <h2 class="text-xl font-bold text-white mb-3">What we collect</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            When you use our contact form or book a call, we collect the information you provide: your name,
            email address, role, and message content. We use privacy-friendly analytics (Plausible) that do not
            use cookies and do not track individuals.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">How we use it</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            We use your information solely to respond to your enquiry, schedule calls, and deliver the services
            you've requested. We do not sell, rent, or share your personal data with third parties for marketing purposes.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Third-party services</h2>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li class="flex items-start gap-2"><span class="text-accent mt-0.5">›</span> <strong class="text-white">Netlify</strong> — hosts our website and processes form submissions</li>
            <li class="flex items-start gap-2"><span class="text-accent mt-0.5">›</span> <strong class="text-white">Cal.com</strong> — handles meeting scheduling</li>
            <li class="flex items-start gap-2"><span class="text-accent mt-0.5">›</span> <strong class="text-white">Plausible Analytics</strong> — cookie-free, privacy-respecting website analytics</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Your rights</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            You can request access to, correction of, or deletion of your personal data at any time by
            contacting us through our <a href="/contact/" class="text-accent hover:text-accent-light transition-colors">contact page</a>.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Contact</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            For privacy-related questions, reach out via our
            <a href="/contact/" class="text-accent hover:text-accent-light transition-colors">contact form</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
