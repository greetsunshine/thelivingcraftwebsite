---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const tagColors: Record<string, string> = {
  violet:  'rgba(79,70,229,0.15)',
  cyan:    'rgba(6,182,212,0.15)',
  pink:    'rgba(236,72,153,0.15)',
  emerald: 'rgba(16,185,129,0.15)',
  amber:   'rgba(245,158,11,0.15)',
};
const tagText: Record<string, string> = {
  violet:  '#818cf8',
  cyan:    '#22d3ee',
  pink:    '#f472b6',
  emerald: '#34d399',
  amber:   '#fbbf24',
};
const statusColors: Record<string, string> = {
  emerald: '#34d399',
  amber:   '#fbbf24',
  gray:    '#6b7280',
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
>

  <style>
    .prose h2 {
      color: white;
      font-size: 1.375rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }
    .prose h3 {
      color: white;
      font-size: 1.0625rem;
      font-weight: 600;
      margin-top: 1.75rem;
      margin-bottom: 0.75rem;
    }
    .prose p {
      color: #d1d5db;
      font-size: 0.9375rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
    }
    .prose ul, .prose ol {
      color: #d1d5db;
      font-size: 0.9375rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }
    .prose li { margin-bottom: 0.5rem; }
    .prose strong { color: white; }
    .prose code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125rem;
      background: rgba(79,70,229,0.1);
      border: 1px solid rgba(79,70,229,0.2);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      color: #a5b4fc;
    }
    .prose pre {
      background: #0d0d18;
      border: 1px solid rgba(75,85,99,0.4);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
      overflow-x: auto;
    }
    .prose pre code {
      background: none; border: none; padding: 0;
      color: #d1d5db; font-size: 0.8125rem;
    }
    .prose hr {
      border: none;
      border-top: 1px solid rgba(75,85,99,0.3);
      margin: 2.5rem 0;
    }
  </style>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative py-20 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 65%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative container mx-auto px-6 max-w-3xl">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-xs font-mono text-gray-400 mb-6">
        <a href="/projects/" class="hover:text-gray-400 transition-colors">Projects</a>
        <span>›</span>
        <span style={`color: ${tagText[project.data.tagColor]};`}>{project.data.tag}</span>
      </div>

      <!-- Status + tag row -->
      <div class="flex items-center gap-3 mb-5">
        <span class="px-2.5 py-1 text-xs font-mono rounded-md"
              style={`background: ${tagColors[project.data.tagColor]}; color: ${tagText[project.data.tagColor]};`}>
          {project.data.tag}
        </span>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full" style={`background: ${statusColors[project.data.statusColor]};`}></span>
          <span class="text-xs font-mono" style={`color: ${statusColors[project.data.statusColor]};`}>
            {project.data.status}
          </span>
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 leading-snug">
        {project.data.title}
      </h1>
      <p class="text-gray-400 text-sm font-mono mb-5">{project.data.subtitle}</p>
      <p class="text-gray-400 text-lg leading-relaxed">{project.data.description}</p>

      <!-- Stack pills -->
      <div class="flex flex-wrap gap-2 mt-6">
        {project.data.stack.map(s => (
          <span class="px-2.5 py-1 text-xs font-mono text-gray-400 bg-dark-secondary border border-gray-700/40 rounded-lg">
            {s}
          </span>
        ))}
      </div>

      <!-- Links -->
      {project.data.links.length > 0 && (
        <div class="flex gap-4 mt-6">
          {project.data.links.map(l => (
            <a href={l.href} target="_blank" rel="noopener"
               class="inline-flex items-center gap-1.5 text-accent hover:text-accent-light text-sm font-medium transition-colors">
              {l.label} →
            </a>
          ))}
        </div>
      )}
    </div>
  </section>


  <!-- ─── PROJECT BODY ─────────────────────────────────────── -->
  <article class="bg-dark-primary py-16">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>


  <!-- ─── BACK + CTA ───────────────────────────────────────── -->
  <section class="bg-dark-secondary py-16">
    <div class="container mx-auto px-6 max-w-3xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <a href="/projects/"
         class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors text-sm font-mono">
        ← All projects
      </a>
      <a href="/contact/?source=other"
         class="inline-flex items-center gap-2 px-6 py-3 text-white font-semibold rounded-xl text-sm transition-opacity hover:opacity-90"
         style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
        Collaborate →
      </a>
    </div>
  </section>

</BaseLayout>
