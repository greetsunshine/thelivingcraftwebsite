---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service"
  description="Terms of service for The Living Craft training, mentoring, and consulting engagements."
>

  <section
    class="relative py-28 overflow-hidden"
    style="background: radial-gradient(ellipse at 50% -5%, #1a1a2e 0%, #0a0a0f 60%);"
  >
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 28px 28px;"></div>

    <div class="relative container mx-auto px-6 max-w-3xl">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Legal</p>
      <h1 class="text-5xl font-bold text-white mb-6 leading-tight">Terms of Service</h1>
      <p class="text-gray-400 text-sm font-mono mb-2">Last updated: April 2026</p>
    </div>
  </section>

  <section class="bg-dark-primary py-20">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="prose prose-invert prose-sm max-w-none space-y-8">

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Agreement</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            By accessing and using thelivingcraft.ai, you agree to these terms. If you do not agree,
            please do not use the site.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Services</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            The Living Craft provides Agentic AI training, mentoring, and consulting services.
            Specific terms for each engagement — including scope, deliverables, pricing, and
            cancellation policy — are agreed upon individually before an engagement begins.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Intellectual property</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            All content on this website — including text, graphics, logos, and blog posts — is the property
            of The Living Craft unless otherwise stated. Materials produced during training and consulting
            engagements are subject to the terms of each individual engagement agreement.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Limitation of liability</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            The Living Craft provides training, mentoring, and consulting on a best-effort basis.
            We do not guarantee specific business outcomes. Our liability is limited to the fees
            paid for the specific engagement in question.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Changes to these terms</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            We may update these terms from time to time. Changes will be posted on this page with
            an updated revision date.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Contact</h2>
          <p class="text-gray-400 text-sm leading-relaxed">
            Questions about these terms? Reach out via our
            <a href="/contact/" class="text-accent hover:text-accent-light transition-colors">contact form</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
